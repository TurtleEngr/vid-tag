# --------------------------------
testExample_NoExec() {
    # When gpNoExec is set, fExample uses a dummy "FILE.mp4" entry with
    # the current wall-clock CreateDate; no real files are touched.
    local tFile="vid-tag-example.txt"
    local tContent
    local tToday

    rm -f "$tFile"

    # Set globals as if -n -e testevent had been parsed
    gpNoExec=1
    gpEventId="testevent"
    gpCaption="Test Caption Body"
    gpCopyright="Copyright Photog 2030"
    gpNameLong="Some Photographer"
    gpNameShort="SP"
    gpEventCity="TestCity"
    gpEventTitle="Test Event Title"
    gpEventKeyword="kw1,kw2"
    gpFilePat='%d_%e_%p_%f'
    gpTitlePat='%D, %c, %E, by %P.'
    gpEventFileList=""
    gpCmdLine="vid-tag -n -e testevent"

    fExample

    assertTrue "$LINENO file created"  "[ -f $tFile ]"

    tContent=$(cat "$tFile")

    # ----- Header sections -----
    assertContains "$LINENO Command hdr"  "$tContent" "Command:"
    assertContains "$LINENO Cmd line"     "$tContent" "vid-tag -n -e testevent"
    assertContains "$LINENO Files hdr"    "$tContent" "Files:"
    assertContains "$LINENO Exif hdr"     "$tContent" "Exif Changes:"

    # ----- Dummy filename: "FILE.mp4" mapped via the file pattern -----
    assertContains "$LINENO dummy in"     "$tContent" "FILE.mp4 -> output/"
    assertContains "$LINENO dummy out"    "$tContent" "_testevent_SP_FILE.mp4"

    # ----- Today's date should appear in Create Date -----
    tToday=$('date' +%Y:%m:%d)
    assertContains "$LINENO today"        "$tContent" "Create Date = $tToday"

    # ----- Tag fields written from gp* values -----
    assertContains "$LINENO Title"        "$tContent" "Title ="
    assertContains "$LINENO TestCity"     "$tContent" "TestCity"
    assertContains "$LINENO Author"       "$tContent" "Author = Some Photographer"
    assertContains "$LINENO Artist"       "$tContent" "Artist = Copyright Photog 2030"
    assertContains "$LINENO Copyright"    "$tContent" "Copyright = Copyright Photog 2030"
    assertContains "$LINENO Keywords"     "$tContent" "Keywords = kw1,kw2"
    assertContains "$LINENO Caption"      "$tContent" "Caption = Test Caption Body"
    assertContains "$LINENO Description"  "$tContent" "Description = (see Caption)"
    assertContains "$LINENO ImageDesc"    "$tContent" "Image Description = (see Caption)"
    assertContains "$LINENO DateTimeOrig" "$tContent" "Date/Time Original = (see Create Date)"
    assertContains "$LINENO ModifyDate"   "$tContent" "Modify Date = (see Create Date)"
    assertContains "$LINENO TrackCreate"  "$tContent" "Track Create Date = (see Create Date)"
    assertContains "$LINENO TrackModify"  "$tContent" "Track Modify Date = (see Create Date)"
    assertContains "$LINENO MediaCreate"  "$tContent" "Media Create Date = (see Create Date)"
    assertContains "$LINENO MediaModify"  "$tContent" "Media Modify Date = (see Create Date)"

    # ----- Single dummy entry → exactly one mapping line -----
    assertEquals "$LINENO 1 entry" "1" \
        "$(grep -c 'FILE.mp4 -> output/' "$tFile")"
    assertEquals "$LINENO idx"     "1" "$gExampleIdx"

    rm -f "$tFile"
    return 0
} # testExample_NoExec

# --------------------------------
testExample_NoExecExtra() {
    # When gpEventExtra is set, fExample appends it (plus a trailing '.')
    # to the title - same rule as fProcessFile.
    local tFile="vid-tag-example.txt"
    local tContent

    rm -f "$tFile"

    gpNoExec=1
    gpEventId="testevent"
    gpCaption="x"
    gpCopyright="x"
    gpNameLong="x"
    gpNameShort="x"
    gpEventCity="x"
    gpEventTitle="Base Title"
    gpEventKeyword="x"
    gpEventExtra="More info"
    gpFilePat='%d_%e_%p_%f'
    gpTitlePat='%E'
    gpCmdLine="vid-tag -n -e testevent"

    fExample
    tContent=$(cat "$tFile")

    assertContains "$LINENO extra appended" "$tContent" \
        "Title = Base Title More info."

    rm -f "$tFile"
    return 0
} # testExample_NoExecExtra

# --------------------------------
testExample_RealFiles() {
    # With gpNoExec=0 and the unzipped test inputs in place, fExample
    # should read each file's exif CreateDate and emit one Files: line
    # plus one Exif Changes block per input.
    local tFile="vid-tag-example.txt"
    local tContent

    if [[ ! -f MVI_0107.MP4 || ! -f MVI_0110.MP4 ]]; then
        fail "$LINENO Missing test files."
        return 0
    fi

    rm -f "$tFile"

    gpNoExec=0
    gpEventId="testevent"
    gpCaption="This photo or video may be downloaded and used freely"
    gpCopyright="Copyright Bruce Rafnel 2026"
    gpNameLong="Bruce Rafnel"
    gpNameShort="BAR"
    gpEventCity="Redwood City"
    gpEventTitle="This is a test title"
    gpEventKeyword="PBP,Protest"
    gpEventExtra=""
    gpFilePat='%d_%e_%p_%f'
    gpTitlePat='%D, %c, %E, by %P.'
    gpEventFileList="MVI_0107.MP4 MVI_0110.MP4"
    gpCmdLine="vid-tag -e testevent MVI_0107.MP4 MVI_0110.MP4"

    fExample

    assertTrue "$LINENO file created" "[ -f $tFile ]"

    tContent=$(cat "$tFile")

    # ----- Header lines -----
    assertContains "$LINENO Command"  "$tContent" "Command:"
    assertContains "$LINENO Cmd line" "$tContent" \
        "vid-tag -e testevent MVI_0107.MP4 MVI_0110.MP4"

    # ----- Files: section: rename mapping per input -----
    assertContains "$LINENO 0107 rename" "$tContent" \
        "MVI_0107.MP4 -> output/2016-11-21_testevent_BAR_MVI_0107.MP4"
    assertContains "$LINENO 0110 rename" "$tContent" \
        "MVI_0110.MP4 -> output/2016-11-21_testevent_BAR_MVI_0110.MP4"

    # ----- Exif Changes blocks: one header + dated CreateDate per file -----
    assertContains "$LINENO 0107 hdr" "$tContent" \
        "2016-11-21_testevent_BAR_MVI_0107.MP4"
    assertContains "$LINENO 0107 title" "$tContent" \
        "Title = 2016-11-21 Mon, Redwood City, This is a test title, by Bruce Rafnel."
    assertContains "$LINENO 0107 cdate" "$tContent" \
        "Create Date = 2016:11:21 00:20:59"

    assertContains "$LINENO 0110 hdr" "$tContent" \
        "2016-11-21_testevent_BAR_MVI_0110.MP4"
    assertContains "$LINENO 0110 title" "$tContent" \
        "Title = 2016-11-21 Mon, Redwood City, This is a test title, by Bruce Rafnel."
    assertContains "$LINENO 0110 cdate" "$tContent" \
        "Create Date = 2016:11:21 00:29:11"

    # ----- Tag fields shared across both files -----
    assertContains "$LINENO Author"   "$tContent" "Author = Bruce Rafnel"
    assertContains "$LINENO Artist"   "$tContent" "Artist = Copyright Bruce Rafnel 2026"
    assertContains "$LINENO Copyright" "$tContent" "Copyright = Copyright Bruce Rafnel 2026"
    assertContains "$LINENO Keywords" "$tContent" "Keywords = PBP,Protest"

    # ----- Two collected entries → two rename lines, idx=2 -----
    assertEquals "$LINENO 2 entries" "2" \
        "$(grep -c '\->\ output/' "$tFile")"
    assertEquals "$LINENO idx" "2" "$gExampleIdx"

    rm -f "$tFile"
    return 0
} # testExample_RealFiles

# --------------------------------
testExampleCollectSplit_Short() {
    # A file under 10 min must NOT produce any split entries.  Use
    # MVI_0107.MP4 (1:36 long) and confirm gExampleIdx stays 0.
    if [[ ! -f MVI_0107.MP4 ]]; then
        fail "$LINENO Missing test files."
        return 0
    fi

    gpEventId="testevent"
    gpNameShort="BAR"
    gpNameLong="Bruce Rafnel"
    gpEventCity="Redwood City"
    gpEventTitle="This is a test title"
    gpEventExtra=""
    gpFilePat='%d_%e_%p_%f'
    gpTitlePat='%D, %c, %E, by %P.'

    gExampleOrigNames=()
    gExampleNewNames=()
    gExampleTitles=()
    gExampleCreateDates=()
    gExampleIdx=0

    fReadFileDate "MVI_0107.MP4"
    fExampleCollectSplit "MVI_0107.MP4" "MVI_0107.MP4" "$gFileDate"

    assertEquals "$LINENO no split entries" "0" "$gExampleIdx"
    return 0
} # testExampleCollectSplit_Short

# --------------------------------
testExampleCollectSplit_Long() {
    # MVI_0746.MP4 is 23:45; fProcessFile would split it into three
    # 10-min parts.  fExampleCollectSplit must mirror that, appending
    # three records with -00/-01/-02 names and CreateDates shifted by
    # 0, 10, and 20 minutes from the parent.
    local i
    if [[ ! -f MVI_0746.MP4 ]]; then
        fail "$LINENO Missing test files."
        return 0
    fi

    gpEventId="testevent"
    gpNameShort="BAR"
    gpNameLong="Bruce Rafnel"
    gpEventCity="Redwood City"
    gpEventTitle="This is a test title"
    gpEventExtra=""
    gpFilePat='%d_%e_%p_%f'
    gpTitlePat='%D, %c, %E, by %P.'

    gExampleOrigNames=()
    gExampleNewNames=()
    gExampleTitles=()
    gExampleCreateDates=()
    gExampleIdx=0

    fReadFileDate "MVI_0746.MP4"
    fExampleCollectSplit "MVI_0746.MP4" "MVI_0746.MP4" "$gFileDate"

    # ----- Three split parts collected -----
    assertEquals "$LINENO 3 split entries" "3" "$gExampleIdx"

    # ----- Each part shares the parent's basename as origin -----
    assertEquals "$LINENO 00 orig" "MVI_0746.MP4" "${gExampleOrigNames[0]}"
    assertEquals "$LINENO 01 orig" "MVI_0746.MP4" "${gExampleOrigNames[1]}"
    assertEquals "$LINENO 02 orig" "MVI_0746.MP4" "${gExampleOrigNames[2]}"

    # ----- Part filenames use "-NN.mp4" (lowercase) -----
    assertEquals "$LINENO 00 name" \
        "2026-03-01_testevent_BAR_MVI_0746-00.mp4" "${gExampleNewNames[0]}"
    assertEquals "$LINENO 01 name" \
        "2026-03-01_testevent_BAR_MVI_0746-01.mp4" "${gExampleNewNames[1]}"
    assertEquals "$LINENO 02 name" \
        "2026-03-01_testevent_BAR_MVI_0746-02.mp4" "${gExampleNewNames[2]}"

    # ----- CreateDate shifted by 0/10/20 min from 19:57:49 -----
    assertEquals "$LINENO 00 cdate" \
        "2026:03:01 19:57:49" "${gExampleCreateDates[0]}"
    assertEquals "$LINENO 01 cdate" \
        "2026:03:01 20:07:49" "${gExampleCreateDates[1]}"
    assertEquals "$LINENO 02 cdate" \
        "2026:03:01 20:17:49" "${gExampleCreateDates[2]}"

    # ----- Title is inherited (same for all parts) -----
    assertEquals "$LINENO 00 title" \
        "${gExampleTitles[0]}" "${gExampleTitles[1]}"
    assertEquals "$LINENO 01 title" \
        "${gExampleTitles[1]}" "${gExampleTitles[2]}"
    return 0
} # testExampleCollectSplit_Long

# --------------------------------
testExample_RealFilesWithSplit() {
    # End-to-end: fExample on MVI_0746.MP4 must write vid-tag-example.txt
    # showing the parent rename plus one entry per split part with the
    # right CreateDate offsets.
    local tFile="vid-tag-example.txt"
    local tContent

    if [[ ! -f MVI_0746.MP4 ]]; then
        fail "$LINENO Missing test files."
        return 0
    fi

    rm -f "$tFile"

    gpNoExec=0
    gpEventId="testevent"
    gpCaption="Test Caption Body"
    gpCopyright="Copyright Bruce Rafnel 2026"
    gpNameLong="Bruce Rafnel"
    gpNameShort="BAR"
    gpEventCity="Redwood City"
    gpEventTitle="This is a test title"
    gpEventKeyword="PBP,Protest"
    gpEventExtra=""
    gpFilePat='%d_%e_%p_%f'
    gpTitlePat='%D, %c, %E, by %P.'
    gpEventFileList="MVI_0746.MP4"
    gpCmdLine="vid-tag -e testevent MVI_0746.MP4"

    fExample

    assertTrue "$LINENO file created" "[ -f $tFile ]"
    tContent=$(cat "$tFile")

    # ----- Files: parent rename plus one per split part -----
    assertContains "$LINENO 0746 rename" "$tContent" \
        "MVI_0746.MP4 -> output/2026-03-01_testevent_BAR_MVI_0746.MP4"
    assertContains "$LINENO 0746 part 00" "$tContent" \
        "MVI_0746.MP4 -> output/2026-03-01_testevent_BAR_MVI_0746-00.mp4"
    assertContains "$LINENO 0746 part 01" "$tContent" \
        "MVI_0746.MP4 -> output/2026-03-01_testevent_BAR_MVI_0746-01.mp4"
    assertContains "$LINENO 0746 part 02" "$tContent" \
        "MVI_0746.MP4 -> output/2026-03-01_testevent_BAR_MVI_0746-02.mp4"

    # ----- Exif Changes block per part with shifted CreateDate -----
    assertContains "$LINENO part 00 hdr"   "$tContent" \
        "2026-03-01_testevent_BAR_MVI_0746-00.mp4"
    assertContains "$LINENO part 00 cdate" "$tContent" \
        "Create Date = 2026:03:01 19:57:49"

    assertContains "$LINENO part 01 hdr"   "$tContent" \
        "2026-03-01_testevent_BAR_MVI_0746-01.mp4"
    assertContains "$LINENO part 01 cdate" "$tContent" \
        "Create Date = 2026:03:01 20:07:49"

    assertContains "$LINENO part 02 hdr"   "$tContent" \
        "2026-03-01_testevent_BAR_MVI_0746-02.mp4"
    assertContains "$LINENO part 02 cdate" "$tContent" \
        "Create Date = 2026:03:01 20:17:49"

    # ----- 1 parent + 3 split parts = 4 mapping lines, idx=4 -----
    assertEquals "$LINENO 4 entries" "4" \
        "$(grep -c '\->\ output/' "$tFile")"
    assertEquals "$LINENO idx" "4" "$gExampleIdx"

    rm -f "$tFile"
    return 0
} # testExample_RealFilesWithSplit

# -------------------
# This should be the last defined function
fRunTests() {
    local tShunit
    
    if [[ -r "$cBin/shunit2.1" ]]; then
        tShunit="$cBin/shunit2.1"
    else
        tShunit="/usr/local/bin/shunit2.1"
    fi
    SHUNIT_COLOR=auto

    case "$gpTest" in
        list)
            grep 'test.*()' $cBin/$cName | grep -v grep | sed 's/()//g; s/{//g'
            exit 1
            ;;
        all)
            gpTest=""
            # shellcheck disable=SC1091,SC1090
            source "$tShunit"
            exit $?
            ;;
        com)
            gpTest=""
            $cBin/bash-com.test
            exit $?
            ;;
        fast)
            gpTest=$(grep 'test.*()' $cBin/$cName | grep -v grep | sed 's/()//g; s/{//g' | grep -v Slow)
            # shellcheck disable=SC1091,SC1090
            source "$tShunit" -- $gpTest
            exit $?
            ;;
        cli)
            gpTest=$(grep 'testCli.*()' $cBin/$cName | grep -v grep | sed 's/()//g; s/{//g')
            # shellcheck disable=SC1091,SC1090
            source "$tShunit" -- $gpTest
            exit $?
            ;;
        not-cli)
            gpTest=$(grep 'test.*()' $cBin/$cName | grep -v grep | sed 's/()//g; s/{//g' | grep -v testCli)
            # shellcheck disable=SC1091,SC1090
            source "$tShunit" -- $gpTest
            exit $?
            ;;
        *)
            # shellcheck disable=SC1091,SC1090
            source "$tShunit" -- $gpTest
            exit $?
            ;;
    esac
    exit

    # shellcheck disable=SC2317
    cat <<EOF >/dev/null
=internal-pod

=internal-head3 fRunTests

Run unit tests for this script using shunit2.1.

=internal-cut
EOF
} # fRunTests

# ========================================
# Main

export cName=${BASH_SOURCE##*/}

# -------------------
# Set cCurDir because PWD may be unset under cron.
if [[ -z "$PWD" ]]; then
    PWD=$(pwd)
fi
cCurDir=$PWD

# -------------------
# Locate the directory that contains this script (and bash-com.inc).
#tBin=home
tBin=this
case $tBin in
    this)    cBin=${BASH_SOURCE%/*} ;;
    current) cBin=$PWD ;;
    home)    cBin=~/bin ;;
    local)   cBin=/usr/local/bin ;;
    system)  cBin=/usr/bin ;;
esac

if [[ ! -x $cBin/bash-com.inc ]]; then
    echo "Error: could not find $cBin/bash-com.inc (Change cBin setting in script.) [$LINENO]"
    exit 1
fi
source $cBin/bash-com.inc

if [[ ! -x $cBin/vid-tag.inc ]]; then
    fLog -p err -m "Could not find $cBin/vid-tag.inc" -l $LINENO
    fUsageTest
fi
source $cBin/vid-tag.inc

# -------------------
# Configuration Section

# shellcheck disable=SC2016
fSetTestGlobals

# -------------------
# Get Args Section

if [[ $# -eq 0 ]]; then
    fLog -p err -m "Missing options." -l $LINENO
    fUsageTest
fi

while getopts :T:hH:lvVd tArg; do
    case $tArg in
        # Script arguments
        T) gpTest="$OPTARG" ;;
        # Common arguments
        h) fUsageTest long;     exit 1 ;;
        H) fUsageTest "$OPTARG"; exit 1 ;;
        l) gpLog=1 ;;
        v) ((++gpVerbose)) ;;
        V) echo "vid-tag.test version: $cVer"
           exit 0
           ;;
        d) ((++gpDebug)) ;;
        # Problem arguments
        :)  fLog -p err -m "Value required for option: -$OPTARG" -l $LINENO
            fUsageTest
            ;;
        \?) fLog -p -m "Unknown option: $OPTARG" -l $LINENO
            fUsageTest
            ;;
    esac
done
((--OPTIND))
shift $OPTIND
if [[ $# -ne 0 ]]; then
    fLog -p err -m "Unknown options: $*" -l $LINENO
    fUsageTest
fi
while [[ $# -ne 0 ]]; do
    shift
done

# -------------------
if [[ -n "$gpTest" ]]; then
    fRunTests
fi
