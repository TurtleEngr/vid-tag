# --------------------------------
testInitialConfig() {
    # Verify the test environment is sane.  setUp forces cName="vid-tag"
    # so the function-level conf tests build the right section names.
    assertEquals "$LINENO cName"      "vid-tag"      "$cName"
    assertNotNull "$LINENO cBin"      "$cBin"
    assertTrue   "$LINENO cBin dir"   "[ -d $cBin ]"
    assertTrue   "$LINENO vid-tag x"  "[ -x $cBin/vid-tag ]"
    assertTrue   "$LINENO vid-tag.inc" "[ -f $cBin/vid-tag.inc ]"
    assertTrue   "$LINENO test files"  "[ -f MVI_0107.MP4 ]"
    assertTrue   "$LINENO conf orig"   "[ -f vid-tag.conf.original ]"
    return 0
} # testInitialConfig

# --------------------------------
testConvertDate() {
    fConvertDate "2024:06:15 10:30:00"

    assertEquals "$LINENO short" "2024-06-15"          "$gFileDateShort"
    assertEquals "$LINENO long"  "2024-06-15 Sat"      "$gFileDateLong"
    assertEquals "$LINENO full"  "2024-06-15_10:30:00" "$gFileDateFull"
    assertEquals "$LINENO touch" "202406151030.00"     "$gFileDateTouch"
    return 0
} # testConvertDate

# --------------------------------
testConvertDate_TestFiles() {
    # Replicate the dates that fReadFileDate would produce for the three
    # test-input files.  Exiftool CreateDates per the input spec:
    #   MVI_0107.MP4  2016:11:21 00:20:59  (Mon)
    #   MVI_0110.MP4  2016:11:21 00:29:11  (Mon)
    #   MVI_0746.MP4  2026:03:01 19:57:49  (Sun)

    # MVI_0107.MP4
    fConvertDate "2016:11:21 00:20:59"
    assertEquals "$LINENO 0107 short" "2016-11-21"          "$gFileDateShort"
    assertEquals "$LINENO 0107 long"  "2016-11-21 Mon"      "$gFileDateLong"
    assertEquals "$LINENO 0107 touch" "201611210020.59"     "$gFileDateTouch"

    # MVI_0110.MP4
    fConvertDate "2016:11:21 00:29:11"
    assertEquals "$LINENO 0110 short" "2016-11-21"          "$gFileDateShort"
    assertEquals "$LINENO 0110 touch" "201611210029.11"     "$gFileDateTouch"

    # MVI_0746.MP4
    fConvertDate "2026:03:01 19:57:49"
    assertEquals "$LINENO 0746 short" "2026-03-01"          "$gFileDateShort"
    assertEquals "$LINENO 0746 long"  "2026-03-01 Sun"      "$gFileDateLong"
    assertEquals "$LINENO 0746 touch" "202603011957.49"     "$gFileDateTouch"
    return 0
} # testConvertDate_TestFiles

# --------------------------------
testApplyPattern() {
    local tResult

    # Set up the globals fApplyPattern reads
    gFileDateShort="2024-06-15"
    gFileDateLong="2024-06-15 Sat"
    gFileDateFull="2024-06-15_10:30:00"
    gpEventId="summer_camp"
    gpEventTitle="Summer Camp 2024"
    gpNameShort="JD"
    gpNameLong="Jane Doe"
    gpEventCity="Springfield"

    #-----
    tResult=$(fApplyPattern '%d_%e_%p_%f' 'clip001.mp4')
    assertEquals "$LINENO file-pat" \
        "2024-06-15_summer_camp_JD_clip001.mp4" "$tResult"

    #-----
    tResult=$(fApplyPattern '%D, %c, %E, by %P.' 'clip001.mp4')
    assertEquals "$LINENO title-pat" \
        "2024-06-15 Sat, Springfield, Summer Camp 2024, by Jane Doe." "$tResult"

    #-----
    # %T expands to gFileDateFull
    tResult=$(fApplyPattern '%T' 'x.mp4')
    assertEquals "$LINENO %T" "2024-06-15_10:30:00" "$tResult"

    # Empty pattern → empty string
    tResult=$(fApplyPattern '' 'x.mp4')
    assertEquals "$LINENO empty" "" "$tResult"

    # Pattern with no tokens passes through unchanged
    tResult=$(fApplyPattern 'literal-text' 'x.mp4')
    assertEquals "$LINENO literal" "literal-text" "$tResult"
    return 0
} # testApplyPattern

# --------------------------------
testApplyPattern_AllTokens() {
    local tResult

    gFileDateShort="2026-03-01"
    gFileDateLong="2026-03-01 Sun"
    gFileDateFull="2026-03-01_19:57:49"
    gpEventId="testevent"
    gpEventTitle="This is a test title"
    gpNameShort="BAR"
    gpNameLong="Bruce Rafnel"
    gpEventCity="Redwood City"

    # Reproduce the %D, %c, %E, by %P. title pattern from the conf
    tResult=$(fApplyPattern '%D, %c, %E, by %P.' 'MVI_0746.MP4')
    assertEquals "$LINENO 0746 title" \
        "2026-03-01 Sun, Redwood City, This is a test title, by Bruce Rafnel." \
        "$tResult"

    # Reproduce the %d_%e_%p_%f file-name pattern
    tResult=$(fApplyPattern '%d_%e_%p_%f' 'MVI_0746.MP4')
    assertEquals "$LINENO 0746 file" \
        "2026-03-01_testevent_BAR_MVI_0746.MP4" "$tResult"
    return 0
} # testApplyPattern_AllTokens

# --------------------------------
testLoadConf() {
    local tConf

    tConf="$cTmp1"

    # Write a minimal config in git-config INI format
    # shellcheck disable=SC2317
    cat >"$tConf" <<'CONF'
[vid-tag "com"]
    caption    = Test Caption
    copyright  = Copyright NAME YYYY
    file-pat   = %d_%e_%p_%f
    title-pat  = %D, %c, %E, by %P.
    name-long  = Test Photographer
    name-short = TP
[vid-tag "test_event"]
    title   = Test Event Title
    city    = Test Village
    keyword = PBP,Protest
CONF

    # Point gpConfLocal at our temp file, set the event id, and reload
    gpConfLocal="$tConf"
    gpEventId="test_event"
    fLoadConf

    assertEquals "$LINENO caption"    "Test Caption"        "$gpCaption"
    assertEquals "$LINENO copyright"  "Copyright NAME YYYY" "$gpCopyright"
    assertEquals "$LINENO name-long"  "Test Photographer"   "$gpNameLong"
    assertEquals "$LINENO name-short" "TP"                  "$gpNameShort"
    assertEquals "$LINENO file-pat"   "%d_%e_%p_%f"         "$gpFilePat"
    assertEquals "$LINENO title-pat"  "%D, %c, %E, by %P."  "$gpTitlePat"
    assertEquals "$LINENO event-title" "Test Event Title"   "$gpEventTitle"
    assertEquals "$LINENO city"       "Test Village"        "$gpEventCity"
    assertEquals "$LINENO keyword"    "PBP,Protest"         "$gpEventKeyword"

    # Restore
    gpConfLocal="./vid-tag.conf"
    return 0
} # testLoadConf

# --------------------------------
testLoadConf_MissingFile() {
    # When gpConfLocal points at a non-existent file, fLoadConf should
    # log info and return 0 without error.
    gpConfLocal="$Tmp/no-such-conf.conf"
    rm -f "$gpConfLocal"
    gpEventId="testevent"

    fLoadConf
    assertTrue "$LINENO missing rc" "[ $? -eq 0 ]"

    # Restore
    gpConfLocal="./vid-tag.conf"
    return 0
} # testLoadConf_MissingFile

# --------------------------------
testLoadConf_NoEventId() {
    local tResult

    # Empty gpEventId → warning, return 0 (no values modified)
    gpEventId=""
    tResult=$(fLoadConf 2>&1)
    assertContains "$LINENO empty msg" "$tResult" "gpEventId not set"

    return 0
} # testLoadConf_NoEventId

# --------------------------------
testLoadConf_EventNotInConf() {
    local tConf
    local tResult

    tConf="$cTmp1"

    # Conf exists, but does not contain a section for our event id
    cat >"$tConf" <<'CONF'
[vid-tag "com"]
    caption = Some Caption
[vid-tag "other_event"]
    title = Some Title
CONF

    gpConfLocal="$tConf"
    gpEventId="missing_event"

    # fError is called → exit; capture output in a subshell
    tResult=$( (fLoadConf) 2>&1 )
    assertContains "$LINENO not-found" "$tResult" "Event not found"

    # Restore
    gpConfLocal="./vid-tag.conf"
    return 0
} # testLoadConf_EventNotInConf

# --------------------------------
testSaveConf() {
    local tConf

    tConf="$cTmp1"
    rm -f "$tConf"

    gpConfLocal="$tConf"
    gpEventId="saveconftest"
    gpCaption="Saved Caption"
    gpCopyright="Saved (c) 2030"
    gpFilePat="%d_%e_%f"
    gpTitlePat="%D %E by %P"
    gpNameLong="Saver Name"
    gpNameShort="SN"
    gpEventTitle="Saved Title"
    gpEventCity="Saved City"
    gpEventKeyword="kw1,kw2"
    gpEventExtra=""
    gpEventFileList=""

    fSaveConf >/dev/null 2>&1

    assertTrue "$LINENO conf created" "[ -f $tConf ]"

    grep -q '\[vid-tag "com"\]'             "$tConf"
    assertTrue "$LINENO com section"        "[ $? -eq 0 ]"

    grep -q '\[vid-tag "saveconftest"\]'    "$tConf"
    assertTrue "$LINENO event section"      "[ $? -eq 0 ]"

    grep -q 'caption = Saved Caption'       "$tConf"
    assertTrue "$LINENO caption"            "[ $? -eq 0 ]"

    grep -q 'copyright = Saved (c) 2030'    "$tConf"
    assertTrue "$LINENO copyright"          "[ $? -eq 0 ]"

    grep -q 'file-pat = %d_%e_%f'           "$tConf"
    assertTrue "$LINENO file-pat"           "[ $? -eq 0 ]"

    grep -q 'name-long = Saver Name'        "$tConf"
    assertTrue "$LINENO name-long"          "[ $? -eq 0 ]"

    grep -q 'name-short = SN'               "$tConf"
    assertTrue "$LINENO name-short"         "[ $? -eq 0 ]"

    grep -q 'title = Saved Title'           "$tConf"
    assertTrue "$LINENO event-title"        "[ $? -eq 0 ]"

    grep -q 'city = Saved City'             "$tConf"
    assertTrue "$LINENO city"               "[ $? -eq 0 ]"

    grep -q 'keyword = kw1,kw2'             "$tConf"
    assertTrue "$LINENO keyword"            "[ $? -eq 0 ]"

    # extra is empty → should NOT be written
    grep -q '^	extra ='                    "$tConf"
    assertFalse "$LINENO no empty extra"    "[ $? -eq 0 ]"

    # Restore
    gpConfLocal="./vid-tag.conf"
    return 0
} # testSaveConf

# --------------------------------
testSaveConf_WithExtra() {
    local tConf

    tConf="$cTmp1"
    rm -f "$tConf"

    gpConfLocal="$tConf"
    gpEventId="extratest"
    gpCaption="x"
    gpCopyright="x"
    gpFilePat="%d_%e_%f"
    gpTitlePat="%D %E by %P"
    gpNameLong="x"
    gpNameShort="x"
    gpEventTitle="x"
    gpEventCity="x"
    gpEventKeyword="x"
    gpEventExtra="An extra line"
    gpEventFileList=""

    fSaveConf >/dev/null 2>&1

    grep -q 'extra = An extra line' "$tConf"
    assertTrue "$LINENO extra written" "[ $? -eq 0 ]"

    gpConfLocal="./vid-tag.conf"
    return 0
} # testSaveConf_WithExtra

# --------------------------------
testSaveConf_NoEventId() {
    local tResult

    gpConfLocal="$cTmp1"
    gpEventId=""

    # fSaveConf with no event id → fError → exit
    tResult=$( (fSaveConf) 2>&1 )
    assertContains "$LINENO no-id msg" "$tResult" "Cannot save local config"

    gpConfLocal="./vid-tag.conf"
    return 0
} # testSaveConf_NoEventId

# --------------------------------
testPreScanOpts() {
    # -e with mixed case + space → lowercased + space-to-underscore
    gpEventId=""
    fPreScanOpts -e "Summer Camp"
    assertEquals "$LINENO summer-camp" "summer_camp" "$gpEventId"

    gpEventId=""
    fPreScanOpts -v -d -e "MyEvent"
    assertEquals "$LINENO myevent" "myevent" "$gpEventId"

    # Other options are ignored by the pre-scan
    gpEventId=""
    fPreScanOpts foo -n -c "City" -e "evt1" -k "kw"
    assertEquals "$LINENO ignores-others" "evt1" "$gpEventId"
    
    return 0
} # testPreScanOpts

# --------------------------------
testPreScanOpts_Missing() {
    local tResult

    # No -e and no pre-set gpEventId → fError → exit
    gpEventId=""
    tResult=$( (fPreScanOpts -n -v -d) 2>&1 )
    assertContains "$LINENO missing -e" "$tResult" "Missing pEventId"
    return 0
} # testPreScanOpts_Missing

# --------------------------------
testGetOpt() {
    # Drive fGetOpt directly and verify each option lands in the right gp*
    fGetOpt -e SomeEvent -c "Town" -C "Cap" -E "Long" -f "%d_%f" \
            -k "k1,k2" -p "AB" -P "Alice B" -R "(c) 2030" \
            -t "%D by %P" -x " more." -n

    assertEquals "$LINENO -e"  "someevent"   "$gpEventId"
    assertEquals "$LINENO -c"  "Town"        "$gpEventCity"
    assertEquals "$LINENO -C"  "Cap"         "$gpCaption"
    assertEquals "$LINENO -E"  "Long"        "$gpEventTitle"
    assertEquals "$LINENO -f"  "%d_%f"       "$gpFilePat"
    assertEquals "$LINENO -k"  "k1,k2"       "$gpEventKeyword"
    assertEquals "$LINENO -p"  "AB"          "$gpNameShort"
    assertEquals "$LINENO -P"  "Alice B"     "$gpNameLong"
    assertEquals "$LINENO -R"  "(c) 2030"    "$gpCopyright"
    assertEquals "$LINENO -t"  "%D by %P"    "$gpTitlePat"
    assertEquals "$LINENO -x"  " more."      "$gpEventExtra"
    assertEquals "$LINENO -n"  "1"           "$gpNoExec"
    return 0
} # testGetOpt

# --------------------------------
testGetOpt_FileList() {
    # Trailing positional args become the gpEventFileList
    fGetOpt -e evt fileA.mp4 fileB.mp4 fileC.mp4
    assertEquals "$LINENO file-list" \
        "fileA.mp4 fileB.mp4 fileC.mp4" "$gpEventFileList"
    return 0
} # testGetOpt_FileList

# --------------------------------
testValidate_OK() {
    # All defaults plus -n so file existence is skipped
    gpFilePat='%d_%e_%p_%f'
    gpTitlePat='%D, %c, %E, by %P.'
    gpNoExec=1
    gpEventFileList=""

    fValidate
    assertTrue "$LINENO ok rc" "[ $? -eq 0 ]"
    return 0
} # testValidate_OK

# --------------------------------
testValidate_BadFilePat() {
    local tResult

    gpFilePat='no-tokens'
    gpTitlePat='%D'
    gpNoExec=1

    tResult=$( (fValidate) 2>&1 )
    assertContains "$LINENO bad-file-pat" "$tResult" "missing % options"
    return 0
} # testValidate_BadFilePat

# --------------------------------
testValidate_BadTitlePat() {
    local tResult

    gpFilePat='%d_%f'
    gpTitlePat='no-tokens'
    gpNoExec=1

    tResult=$( (fValidate) 2>&1 )
    assertContains "$LINENO bad-title-pat" "$tResult" "missing % options"
    return 0
} # testValidate_BadTitlePat

# --------------------------------
testValidate_NoFiles() {
    local tResult

    gpFilePat='%d_%f'
    gpTitlePat='%D %P'
    gpNoExec=0
    gpEventFileList=""

    tResult=$( (fValidate) 2>&1 )
    assertContains "$LINENO no-files" "$tResult" "No input files given"
    return 0
} # testValidate_NoFiles

# --------------------------------
testValidate_MissingFile() {
    local tResult

    gpFilePat='%d_%f'
    gpTitlePat='%D %P'
    gpNoExec=0
    gpEventFileList="/no/such/file.mp4"

    tResult=$( (fValidate) 2>&1 )
    assertContains "$LINENO missing-file" "$tResult" "File not found"
    return 0
} # testValidate_MissingFile

# --------------------------------
testValidate_FilesExist() {
    # The unzipped test files should exist in the cwd
    gpFilePat='%d_%f'
    gpTitlePat='%D %P'
    gpNoExec=0
    gpEventFileList="MVI_0107.MP4 MVI_0110.MP4 MVI_0746.MP4"

    fValidate
    assertTrue "$LINENO existing-files rc" "[ $? -eq 0 ]"
    return 0
} # testValidate_FilesExist

# -------------------
# This should be the last defined function
fRunTests() {
    local tShunit
    
    if [[ -r "$cBin/shunit2.1" ]]; then
        tShunit="$cBin/shunit2.1"
    else
        tShunit="/usr/local/bin/shunit2.1"
    fi
    SHUNIT_COLOR=auto

    case "$gpTest" in
        list)
            grep 'test.*()' $cBin/$cName | grep -v grep | sed 's/()//g; s/{//g'
            exit 1
            ;;
        all)
            gpTest=""
            # shellcheck disable=SC1091,SC1090
            source "$tShunit"
            exit $?
            ;;
        com)
            gpTest=""
            $cBin/bash-com.test
            exit $?
            ;;
        cli)
            gpTest=$(grep 'testCli.*()' $cBin/$cName | grep -v grep | sed 's/()//g; s/{//g')
            # shellcheck disable=SC1091,SC1090
            source "$tShunit" -- $gpTest
            exit $?
            ;;
        not-cli)
            gpTest=$(grep 'test.*()' $cBin/$cName | grep -v grep | sed 's/()//g; s/{//g' | grep -v testCli)
            # shellcheck disable=SC1091,SC1090
            source "$tShunit" -- $gpTest
            exit $?
            ;;
        *)
            # shellcheck disable=SC1091,SC1090
            source "$tShunit" -- $gpTest
            exit $?
            ;;
    esac
    exit

    # shellcheck disable=SC2317
    cat <<EOF >/dev/null
=internal-pod

=internal-head3 fRunTests

Run unit tests for this script using shunit2.1.

=internal-cut
EOF
} # fRunTests

# ========================================
# Main

export cName=${BASH_SOURCE##*/}

# -------------------
# Set cCurDir because PWD may be unset under cron.
if [[ -z "$PWD" ]]; then
    PWD=$(pwd)
fi
cCurDir=$PWD

# -------------------
# Locate the directory that contains this script (and bash-com.inc).
#tBin=home
tBin=current
case $tBin in
    current) cBin=$PWD ;;
    home)    cBin=~/bin ;;
    local)   cBin=/usr/local/bin ;;
    system)  cBin=/usr/bin ;;
    this)    cBin=${BASH_SOURCE%/*} ;;
esac

if [[ ! -x $cBin/bash-com.inc ]]; then
    echo "Error: could not find $cBin/bash-com.inc (Change cBin setting in script.) [$LINENO]"
    exit 1
fi
source $cBin/bash-com.inc

if [[ ! -x $cBin/vid-tag.inc ]]; then
    fLog -p err -m "Could not find $cBin/vid-tag.inc" -l $LINENO
    fUsageTest
fi
source $cBin/vid-tag.inc

# -------------------
# Configuration Section

# shellcheck disable=SC2016
fSetTestGlobals

# -------------------
# Get Args Section

if [[ $# -eq 0 ]]; then
    fLog -p err -m "Missing options." -l $LINENO
    fUsageTest
fi

while getopts :T:hH:lvVd tArg; do
    case $tArg in
        # Script arguments
        T) gpTest="$OPTARG" ;;
        # Common arguments
        h) fUsageTest long;     exit 1 ;;
        H) fUsageTest "$OPTARG"; exit 1 ;;
        l) gpLog=1 ;;
        v) ((++gpVerbose)) ;;
        V) echo "vid-tag.test version: $cVer"
           exit 0
           ;;
        d) ((++gpDebug)) ;;
        # Problem arguments
        :)  fLog -p err -m "Value required for option: -$OPTARG" -l $LINENO
            fUsageTest
            ;;
        \?) fLog -p -m "Unknown option: $OPTARG" -l $LINENO
            fUsageTest
            ;;
    esac
done
((--OPTIND))
shift $OPTIND
if [[ $# -ne 0 ]]; then
    fLog -p err -m "Unknown options: $*" -l $LINENO
    fUsageTest
fi
while [[ $# -ne 0 ]]; do
    shift
done

# -------------------
if [[ -n "$gpTest" ]]; then
    fRunTests
fi
