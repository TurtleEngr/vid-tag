    # All defaults plus -n so file existence is skipped
    gpFilePat='%d_%e_%p_%f'
    gpTitlePat='%D, %c, %E, by %P.'
    gpNoExec=1
    gpEventFileList=""

    fValidate
    assertTrue "$LINENO ok rc" "[ $? -eq 0 ]"
    return 0
} # testValidate_OK

