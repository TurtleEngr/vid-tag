#!/usr/bin/env bash
# $Source: /repo/video.cvs/studio/probonophoto/label/vid-tag.test,v $
# $Revision: 1.10 $ $Date: 2026/04/29 18:27:22 $ GMT
set -u

export cVer=2.1

# --------------------------------
fUsageTest() {
    # Quick help, run this:
    # vid-tag -h

    local pStyle="${1:-usage}"

    case $pStyle in
        short | usage | man | long | text | md)
            fComUsage -f $cBin/$cName -s $pStyle
            ;;
        html)
            fComUsage -f $cBin/$cName -s $pStyle -t "$cName Usage"
            ;;
        *)
            fComUsage -f $cBin/$cName -s short
            ;;
    esac
    exit 1

    # POD Syntax: https://perldoc.perl.org/perlpod
    # shellcheck disable=SC2317
    cat <<EOF >/dev/null
=pod

=for text ========================================

=for html <hr/>

=head1 NAME vid-tag.test

Test vid-tag

=head1 SYNOPSIS

    vid-tag.test [-h] [-h pStyle]
    vid-tag.test -T list [-v] [-d]
    vid-tag.test -T all [-v] [-d]
    vid-tag.test -T fast [-v] [-d]
    vid-tag.test -T cli [-v] [-d]
    vid-tag.test -T not-cli [-v] [-d]
    vid-tag.test -T com [-v] [-d]
    vid-tag.test -T "pTest pTest..." [-v] [-d]

=head1 DESCRIPTION

Run unit and integration tests against vid-tag and vid-tag.inc.

The test data archive C<vid-tag-test-input.zip> must exist in the
current directory; it is unzipped during oneTimeSetUp and supplies
three video files plus a sample C<vid-tag.conf>.

The number in the asssert messages (ASSERT:282 msg), is the line
number for assert test that failed.

=head1 OPTIONS

=over 4

=item B<-T "pTest">

Run the unit test functions in this script.

"B<-T all>" runs all functions that begin with "test".

"B<-T fast>" runs all functions that do not have "Slow" in their name (~10sec)".

"B<-T cli>" runs all functions that begin with "testCli (~6min)".

"B<-T not-cli>" runs all functions that begin with "test", but not
"testCli".

"B<-T list>" lists all test function names.

"B<-T com>" runs all tests for bash-com.inc.

=back

=head1 RETURN VALUE

0 on success; non-zero on error.

=head1 ERRORS

Look for the assert errors.

If you have not unzipped vid-tag-test-input.zip in the current
directory you will see these assert errors: "Missing test files" or
"expected test files"

=head1 FILES

    vid-tag
    vid-tag.inc
    vid-tag.test - this file
    vid-tag-test-input.zip - input files
    bash-com.inc
    bash-com.test
    shunit2.1

=head1 SEE ALSO

Required programs: bash, exiftool, ffmpeg, sed

=head1 AUTHOR

Turtle Engineer

=head1 HISTORY

GPLv2 (c) Copyright

cVer=2.1

=cut
EOF
} # fUsageTest

# -------------------
fSetTestGlobals() {
    fComSetGlobals
    fComCheckDeps "bash exiftool ffmpeg sed" "cat"
    return 0
} # fSetTestGlobals

# -------------------
fStripLine() {
    # Remove the trailing " [NNN]" or "[NNN](NN)" line-number marker
    # that fLog/fError appends, so tests can match message text
    # without depending on vid-tag.inc or bash-com.inc line numbers.
    sed -E 's/ \[[0-9]+\]//; s/\([0-9]+\)$//'
} # fStripLine

# ========================================
# Tests

# --------------------------------
oneTimeSetUp() {
    # gpTest=''
    echo $gpTest | grep -q 'testCli.*()' >/dev/null 2>&1
    if [[ $? -eq 0 ]]; then
        if [[ ! -f vid-tag-test-input.zip ]]; then
            fLog -p err -m "Missing: vid-tag-test-input.zip" -l $LINENO
            fUsageTest
        fi
        unzip -o vid-tag-test-input.zip >/dev/null
    fi

    if [[ -f vid-tag.conf ]]; then
        cp vid-tag.conf vid-tag.conf.sav
    fi

    # Create default vid-tag.conf in the new bash-include format.
    cat <<'EOF' >vid-tag.conf
# vid-tag local config (bash include format)
Caption="This photo or video may be downloaded and used freely for non-commercial purposes or by bona fide media services, provided that the photographer and ProbonoPhoto are credited whenever it is used. (https://www.probonophoto.org/Who-We-Are/Bruce-Rafnel). The photographer retains copyright to this image. This is a CC-NC-BY-4.0 license: https://creativecommons.org/licenses/by-nc/4.0/"
Copyright="Copyright Bruce Rafnel 2026"
FilePat="%d_%e_%p_%f"
NameLong="Bruce Rafnel"
NameShort="BAR"
TitlePat="%D, %c, %E, by %P."
Event="testevent"
City="Redwood City"
Title="This is a test title"
Keyword="PBP,Protest"
EOF

    # Save a pristine copy of the conf so setUp can restore it before
    # every test that mutates ./vid-tag.conf.
    if [[ -f vid-tag.conf ]]; then
        cp vid-tag.conf vid-tag.conf.original
    fi

    return 0
} # oneTimeSetUp

# --------------------------------
oneTimeTearDown() {
    rm -f vid-tag.conf.original 2>/dev/null
    if [[ -f vid-tag.conf.sav ]]; then
        mv -f vid-tag.conf.sav vid-tag.conf 
    fi

    return 0
} # oneTimeTearDown

# --------------------------------
setUp() {
    # Restore conf for each test (so tests run in any order)
    if [[ -f vid-tag.conf.original ]]; then
        cp vid-tag.conf.original vid-tag.conf
    fi

    # The test script's BASH_SOURCE name is "vid-tag.test", so force
    # cName to "vid-tag" so that any code keyed off cName (e.g. the
    # conf path resolution in $cBin/$cName.inc) is consistent with
    # what the real ./vid-tag script sees.
    cName="vid-tag"

    # Reset the gp* globals that fLoadConf / fApplyPattern / fValidate
    # read.  Match the defaults in fSetGlobals.
    gpEventId=""
    gpEventCity="TBD"
    gpEventTitle="TBD"
    gpEventKeyword="TBD"
    gpEventFileList=""
    gpCaption="Copyright TERMS"
    gpCopyright="Copyright NAME YYYY"
    gpFilePat='%d_%e_%p_%f'
    gpTitlePat='%D, %c, %E, by %P.'
    gpNameLong="TBD"
    gpNameShort="TBD"
    gpTimeZone=""
    gpNoExec=0
    gpVerbose=0
    gpDebug=0

    # Per-file extras: populated by fLoadConf from Extra[...] lines.
    declare -gA gExtraMap=()

    # Per-file globals
    gFile=""
    gFileDate=""
    gFileDateFull=""
    gFileDateLong=""
    gFileDateShort=""
    gFileDateTouch=""

    # Output dir constant (set by fSetGlobals normally)
    cOutputDir="output"
    cExampleFile="vid-tag-example.txt"
    gpConfLocal="./vid-tag.conf"
    return 0
} # setUp

# --------------------------------
tearDown() {
    if [[ -d ./output ]]; then
        rm -rf ./output
    fi
    return 0
} # tearDown

# ========================================
# CLI tests (test ./vid-tag binary)
# ========================================

# --------------------------------
testCliUsage() {
    local tResult

    #-----
    tResult=$($cBin/vid-tag 2>&1)
    assertContains "$LINENO no-args usage" "$tResult" "Usage:"

    #-----
    tResult=$($cBin/vid-tag -H short 2>&1)
    assertContains "$LINENO short 1" "$tResult" "NAME vid-tag"
    assertContains "$LINENO short 2" "$tResult" "SYNOPSIS"
    assertContains "$LINENO short 3" "$tResult" "DESCRIPTION"

    #-----
    tResult=$($cBin/vid-tag -H long 2>&1)
    assertContains "$LINENO long.1" "$tResult" "DESCRIPTION"
    assertContains "$LINENO long.2" "$tResult" "HISTORY"

    #-----
    tResult=$($cBin/vid-tag -H man 2>&1)
    assertContains "$LINENO man.1" "$tResult" '.IX Header "DESCRIPTION"'
    assertContains "$LINENO man.2" "$tResult" '.IX Header "HISTORY"'

    #-----
    tResult=$($cBin/vid-tag -H html 2>&1)
    assertContains "$LINENO html.1" "$tResult" '<a href="#DESCRIPTION">DESCRIPTION</a>'
    assertContains "$LINENO html.2" "$tResult" '<h1 id="HISTORY">HISTORY</h1>'
    assertContains "$LINENO html.3" "$tResult" "<title>vid-tag Usage</title>"

    #-----
    tResult=$($cBin/vid-tag -H md 2>&1)
    assertContains "$LINENO md.1" "$tResult" '# DESCRIPTION'
    assertContains "$LINENO md.2" "$tResult" '# HISTORY'

    #-----
    tResult=$($cBin/vid-tag -h 2>&1)
    assertContains "$LINENO -h.1" "$tResult" "DESCRIPTION"
    assertContains "$LINENO -h.2" "$tResult" "OPTIONS"

    return 0
} # testCliUsage

# --------------------------------
testCliVersion() {
    local tResult

    tResult=$($cBin/vid-tag -V 2>&1)
    assertContains "$LINENO -V version" "$tResult" "vid-tag version:"
    return 0
} # testCliVersion

# --------------------------------
testCliMissingArgs() {
    local tResult

    # vid-tag with no args at all → "Missing required options."
    tResult=$($cBin/vid-tag 2>&1)
    assertContains "$LINENO no-args" "$tResult" "Usage:"
    return 0
} # testCliMissingArgs

# --------------------------------
testCliMissingEventId() {
    local tResult

    # When there is no existing conf AND no -e on the command line,
    # fValidate must fire "Missing pEventId".  The setUp helper
    # restores vid-tag.conf from vid-tag.conf.original which has
    # Event="testevent", so remove it here first to clear gpEventId.
    rm -f ./vid-tag.conf

    # -n alone (no -e) → "Missing pEventId"
    tResult=$($cBin/vid-tag -n 2>&1)
    assertContains "$LINENO no-e" "$tResult" "Missing pEventId"
    return 0
} # testCliMissingEventId

# --------------------------------
testCliUnknownOption() {
    local tResult

    tResult=$($cBin/vid-tag -e testevent -Z 2>&1)
    assertContains "$LINENO unknown-opt" "$tResult" "Unknown option"
    return 0
} # testCliUnknownOption

# --------------------------------
testCliMissingOptArg() {
    local tResult

    # -c without value → "Value required"
    tResult=$($cBin/vid-tag -e testevent -c 2>&1)
    assertContains "$LINENO no-value-c" "$tResult" "Value required"
    return 0
} # testCliMissingOptArg

# --------------------------------
testCliNoExec() {
    local tResult

    # -n + existing testevent conf (from oneTimeSetUp) → dry run
    tResult=$($cBin/vid-tag -v -n -e testevent 2>&1)
    assertContains "$LINENO no-exec msg" "$tResult" "No-execute"
    assertContains "$LINENO no-exec conf" "$tResult" "vid-tag.conf"

    # output dir must NOT have been created
    assertFalse "$LINENO no output dir" "[ -d ./output ]"
    return 0
} # testCliNoExec

# --------------------------------
testCliNoExecCreatesNewConf() {
    local tResult

    # Remove the conf so we can verify fresh-create behavior
    rm -f ./vid-tag.conf

    tResult=$($cBin/vid-tag -n -e brandnew 2>&1)

    # Conf should now exist
    assertTrue "$LINENO conf created" "[ -f ./vid-tag.conf ]"

    # Conf must be valid bash (sourcing must succeed).
    bash -n ./vid-tag.conf
    assertTrue "$LINENO conf bash-syntax OK" "[ $? -eq 0 ]"

    # Conf should contain the standard variable assignments.
    grep -q '^Caption='   ./vid-tag.conf
    assertTrue "$LINENO Caption var"  "[ $? -eq 0 ]"

    grep -q '^Copyright=' ./vid-tag.conf
    assertTrue "$LINENO Copyright var" "[ $? -eq 0 ]"

    grep -q '^Event="brandnew"' ./vid-tag.conf
    assertTrue "$LINENO Event=brandnew" "[ $? -eq 0 ]"
    return 0
} # testCliNoExecCreatesNewConf

# --------------------------------
testCliConfCreatedIfMissing() {
    # Explicit test of the spec requirement: if vid-tag.conf does not
    # exist when vid-tag is invoked, fLoadConf (via fSaveConf) MUST
    # create it.  Verify the file appears and contains valid bash.
    local tResult

    rm -f ./vid-tag.conf
    assertFalse "$LINENO precondition: no conf" "[ -f ./vid-tag.conf ]"

    tResult=$($cBin/vid-tag -n -e createtest 2>&1)

    assertTrue  "$LINENO conf was created"  "[ -f ./vid-tag.conf ]"
    bash -n ./vid-tag.conf
    assertTrue  "$LINENO conf is valid bash" "[ $? -eq 0 ]"

    # Re-sourcing the file must round-trip the Event value.
    (
        Event=""
        # shellcheck disable=SC1091
        source ./vid-tag.conf
        [[ "$Event" = "createtest" ]]
    )
    assertTrue  "$LINENO Event round-trips" "[ $? -eq 0 ]"
    return 0
} # testCliConfCreatedIfMissing

# --------------------------------
testCliEventLowercase() {
    local tResult

    rm -f ./vid-tag.conf

    # gpEventId is "declare -lx", so MixedCase should become mixedcase
    tResult=$($cBin/vid-tag -n -e MixedCASE 2>&1)

    grep -q '^Event="mixedcase"' ./vid-tag.conf
    assertTrue "$LINENO lowercased" "[ $? -eq 0 ]"

    grep -q '^Event="MixedCASE"' ./vid-tag.conf
    assertFalse "$LINENO not original case" "[ $? -eq 0 ]"
    return 0
} # testCliEventLowercase

# --------------------------------
testCliEventSpaceUnderscore() {
    rm -f ./vid-tag.conf

    # Spaces in -e are converted to underscores
    $cBin/vid-tag -n -e "two words" >/dev/null 2>&1

    grep -q '^Event="two_words"' ./vid-tag.conf
    assertTrue "$LINENO space->underscore" "[ $? -eq 0 ]"
    return 0
} # testCliEventSpaceUnderscore

# --------------------------------
testCliCity() {
    $cBin/vid-tag -n -e testevent -c "Sample City" >/dev/null 2>&1

    grep -q '^City="Sample City"' ./vid-tag.conf
    assertTrue "$LINENO city saved" "[ $? -eq 0 ]"
    return 0
} # testCliCity

# --------------------------------
testCliCaption() {
    $cBin/vid-tag -n -e testevent -C "My test caption" >/dev/null 2>&1

    grep -q '^Caption="My test caption"' ./vid-tag.conf
    assertTrue "$LINENO caption saved" "[ $? -eq 0 ]"
    return 0
} # testCliCaption

# --------------------------------
testCliCopyright() {
    $cBin/vid-tag -n -e testevent -R "Copyright Foo Bar 2030" >/dev/null 2>&1

    grep -q '^Copyright="Copyright Foo Bar 2030"' ./vid-tag.conf
    assertTrue "$LINENO copyright saved" "[ $? -eq 0 ]"
    return 0
} # testCliCopyright

# --------------------------------
testCliEventTitle() {
    $cBin/vid-tag -n -e testevent -E "Long Event Description" >/dev/null 2>&1

    grep -q '^Title="Long Event Description"' ./vid-tag.conf
    assertTrue "$LINENO event title saved" "[ $? -eq 0 ]"
    return 0
} # testCliEventTitle

# --------------------------------
testCliKeyword() {
    $cBin/vid-tag -n -e testevent -k "kw1,kw2,kw3" >/dev/null 2>&1

    grep -q '^Keyword="kw1,kw2,kw3"' ./vid-tag.conf
    assertTrue "$LINENO keyword saved" "[ $? -eq 0 ]"
    return 0
} # testCliKeyword

# --------------------------------
testCliShortName() {
    $cBin/vid-tag -n -e testevent -p ZZZ >/dev/null 2>&1

    grep -q '^NameShort="ZZZ"' ./vid-tag.conf
    assertTrue "$LINENO short name saved" "[ $? -eq 0 ]"
    return 0
} # testCliShortName

# --------------------------------
testCliLongName() {
    $cBin/vid-tag -n -e testevent -P "Some Photographer" >/dev/null 2>&1

    grep -q '^NameLong="Some Photographer"' ./vid-tag.conf
    assertTrue "$LINENO long name saved" "[ $? -eq 0 ]"
    return 0
} # testCliLongName

# --------------------------------
testCliFilePattern() {
    $cBin/vid-tag -n -e testevent -f '%d-%e-%f' >/dev/null 2>&1

    grep -q '^FilePat="%d-%e-%f"' ./vid-tag.conf
    assertTrue "$LINENO FilePat saved" "[ $? -eq 0 ]"
    return 0
} # testCliFilePattern

# --------------------------------
testCliBadFilePattern() {
    local tResult

    # File pattern without any %tokens → fError "missing % options"
    tResult=$($cBin/vid-tag -n -e testevent -f "no-tokens-here" 2>&1)
    assertContains "$LINENO bad file-pat" "$tResult" "missing % options"
    return 0
} # testCliBadFilePattern

# --------------------------------
testCliTitlePattern() {
    $cBin/vid-tag -n -e testevent -t '%D %E by %P' >/dev/null 2>&1

    grep -q '^TitlePat="%D %E by %P"' ./vid-tag.conf
    assertTrue "$LINENO TitlePat saved" "[ $? -eq 0 ]"
    return 0
} # testCliTitlePattern

# --------------------------------
testCliBadTitlePattern() {
    local tResult

    tResult=$($cBin/vid-tag -n -e testevent -t "no tokens" 2>&1)
    assertContains "$LINENO bad title-pat" "$tResult" "missing % options"
    return 0
} # testCliBadTitlePattern

# --------------------------------
testCliTimeZone() {
    # -z value should land in the conf as TimeZone="<value>"
    $cBin/vid-tag -n -e testevent -z "utc-1" >/dev/null 2>&1

    grep -q '^TimeZone="utc-1"' ./vid-tag.conf
    assertTrue "$LINENO TimeZone saved" "[ $? -eq 0 ]"
    return 0
} # testCliTimeZone

# --------------------------------
testCliTimeZoneVariants() {
    # All documented format variants should be accepted by fValidate
    # and round-trip through the conf file.
    local tTz

    for tTz in "UTC-1" "UTC+8" "UTC-5:30" "UTC+3:45" "utc-12" "local"; do
        $cBin/vid-tag -n -e testevent -z "$tTz" >/dev/null 2>&1
        grep -qF "TimeZone=\"$tTz\"" ./vid-tag.conf
        assertTrue "$LINENO $tTz saved" "[ $? -eq 0 ]"
    done
    return 0
} # testCliTimeZoneVariants

# --------------------------------
testCliBadTimeZone() {
    local tResult

    # An unparseable TimeZone should fError out of fValidate
    tResult=$($cBin/vid-tag -n -e testevent -z "garbage" 2>&1)
    assertContains "$LINENO bad tz" "$tResult" "Invalid TimeZone"
    return 0
} # testCliBadTimeZone

# --------------------------------
testCliFileNotFound() {
    local tResult

    # Without -n, fValidate does check files; missing file → fatal
    tResult=$($cBin/vid-tag -e testevent /no/such/file.mp4 2>&1)
    assertContains "$LINENO missing file" "$tResult" "File not found"
    return 0
} # testCliFileNotFound

# --------------------------------
testCliVerboseLevels() {
    local tDefault
    local tV
    local tVV

    # Default verbose: only warning+. The notice "No-execute" message
    # should NOT appear.
    tDefault=$($cBin/vid-tag -n -e testevent 2>&1)
    # "No-execute" is at notice level, not visible by default
    if echo "$tDefault" | grep -q "No-execute"; then
        fail "$LINENO default level should NOT show notice"
    fi

    # -v: notice and above. "No-execute" SHOULD appear.
    tV=$($cBin/vid-tag -v -n -e testevent 2>&1)
    assertContains "$LINENO -v shows notice" "$tV" "No-execute"

    # -vv: info and above. "Saving local config" SHOULD appear.
    tVV=$($cBin/vid-tag -vv -n -e testevent 2>&1)
    assertContains "$LINENO -vv shows info" "$tVV" "Saving local config"
    return 0
} # testCliVerboseLevels

# --------------------------------
testCliReadsExistingConf() {
    local tResult

    # The default vid-tag.conf (from oneTimeSetUp) has Event="testevent",
    # NameShort="BAR", NameLong="Bruce Rafnel", Title="This is a test
    # title", City="Redwood City", Keyword="PBP,Protest".
    # Running -n -e testevent should round-trip these values back to
    # the conf without losing them.
    $cBin/vid-tag -n -e testevent >/dev/null 2>&1

    grep -q '^NameShort="BAR"' ./vid-tag.conf
    assertTrue "$LINENO BAR preserved" "[ $? -eq 0 ]"

    grep -q '^NameLong="Bruce Rafnel"' ./vid-tag.conf
    assertTrue "$LINENO Bruce Rafnel preserved" "[ $? -eq 0 ]"

    grep -q '^City="Redwood City"' ./vid-tag.conf
    assertTrue "$LINENO Redwood City preserved" "[ $? -eq 0 ]"

    grep -q '^Title="This is a test title"' ./vid-tag.conf
    assertTrue "$LINENO title preserved" "[ $? -eq 0 ]"

    grep -q '^Keyword="PBP,Protest"' ./vid-tag.conf
    assertTrue "$LINENO keyword preserved" "[ $? -eq 0 ]"
    return 0
} # testCliReadsExistingConf

# --------------------------------
testCliCmdLineOverridesConf() {
    # The conf has City="Redwood City"; -c overrides it
    $cBin/vid-tag -n -e testevent -c "OVERRIDE City" >/dev/null 2>&1

    grep -q '^City="OVERRIDE City"' ./vid-tag.conf
    assertTrue "$LINENO override city" "[ $? -eq 0 ]"

    grep -q '^City="Redwood City"' ./vid-tag.conf
    assertFalse "$LINENO old city gone" "[ $? -eq 0 ]"
    return 0
} # testCliCmdLineOverridesConf

# --------------------------------
testCliTimeZoneFromConfSlow() {
    # Integration test: with TimeZone defined in vid-tag.conf, the
    # generated vid-tag-example.txt must show CreateDate values that
    # have been converted from the configured TimeZone to local time,
    # and the new file name must use the converted date.
    #
    # Per the spec example:
    #   gpTimeZone="utc-1"
    #   "2026-05-02 01:00:00" -> "2026-05-01 17:00:00" (in PDT)
    #
    # MVI_0107.MP4 has CreateDate 2016:11:21 00:20:59.  Interpreting
    # that as utc-1 (one hour AHEAD of UTC) yields 2016:11:20 23:20:59
    # UTC, which on the test host (TZ pinned to America/Los_Angeles,
    # PST in November = UTC-8) becomes 2016:11:20 15:20:59.
    #
    # NOTE: Slow - requires the MVI_0107.MP4 input file.
    local tResult
    local tSavedTZ="${TZ-}"

    if [[ ! -f MVI_0107.MP4 ]]; then
        fail "$LINENO Missing test files."
        return 0
    fi

    # Pin the host TZ so the converted result is deterministic.
    export TZ="America/Los_Angeles"

    # ---- Build a vid-tag.conf (bash-include) with TimeZone set ----
    cat > vid-tag.conf <<'CONF'
Caption="Test caption"
Copyright="Copyright Test 2026"
FilePat="%d_%e_%p_%f"
NameLong="Test Photog"
NameShort="TP"
TitlePat="%D, %c, %E, by %P."
Event="tzevent"
City="Testville"
Title="TZ Test Event"
Keyword="tz,test"
TimeZone="utc-1"
CONF

    # ---- Run in -n mode against MVI_0107 to drive fExample ----
    rm -f vid-tag-example.txt
    rm -rf ./output
    tResult=$($cBin/vid-tag -n -e tzevent MVI_0107.MP4 2>&1)
    assertTrue "$LINENO example file created" "[ -f vid-tag-example.txt ]"

    # ---- vid-tag-example.txt must show the converted CreateDate ----
    grep -q 'Create Date = 2016:11:20 15:20:59' vid-tag-example.txt
    assertTrue "$LINENO example shows converted cdate" "[ $? -eq 0 ]"

    # ---- The new filename uses the converted date prefix ----
    grep -q 'MVI_0107.MP4 -> output/2016-11-20_tzevent_TP_MVI_0107.MP4' \
        vid-tag-example.txt
    assertTrue "$LINENO example shows converted name" "[ $? -eq 0 ]"

    # ---- The unconverted date must NOT appear ----
    grep -q 'Create Date = 2016:11:21 00:20:59' vid-tag-example.txt
    assertFalse "$LINENO original cdate not present" "[ $? -eq 0 ]"

    # ---- TimeZone setting round-trips back to the conf ----
    grep -q '^TimeZone="utc-1"' vid-tag.conf
    assertTrue "$LINENO TimeZone preserved" "[ $? -eq 0 ]"

    # ---- Sanity: with -z local on the cmd line, override the conf ----
    rm -f vid-tag-example.txt
    $cBin/vid-tag -n -e tzevent -z local MVI_0107.MP4 >/dev/null 2>&1
    grep -q 'Create Date = 2016:11:21 00:20:59' vid-tag-example.txt
    assertTrue "$LINENO local override no conversion" "[ $? -eq 0 ]"

    if [[ -n "$tSavedTZ" ]]; then
        export TZ="$tSavedTZ"
    else
        unset TZ
    fi
    return 0
} # testCliTimeZoneFromConfSlow

# --------------------------------
testCliTimeZoneExifSlow() {
    # Full-pipeline test: run vid-tag (without -n) against MVI_0107.MP4
    # with TimeZone=utc-1 and verify that ALL seven date/time exif fields
    # in the output file plus the filesystem mtime carry the converted
    # local time, and that the output filename uses the converted date.
    #
    # MVI_0107 CreateDate: 2016:11:21 00:20:59 (utc-1 = UTC+1)
    #   → 2016-11-20 23:20:59 UTC → PST (UTC-8 in Nov): 2016:11:20 15:20:59
    #
    # NOTE: Slow - requires the MVI_0107.MP4 input file.
    local tExif
    local tFile
    local tSavedTZ="${TZ-}"
    local tResult

    if [[ ! -f MVI_0107.MP4 ]]; then
        fail "$LINENO Missing test files."
        return 0
    fi

    export TZ="America/Los_Angeles"

    cat > vid-tag.conf <<'CONF'
Caption="Test caption"
Copyright="Copyright Test 2026"
FilePat="%d_%e_%p_%f"
NameLong="Test Photog"
NameShort="TP"
TitlePat="%D, %c, %E, by %P."
Event="tzevent"
City="Testville"
Title="TZ Test Event"
Keyword="tz,test"
TimeZone="utc-1"
CONF

    rm -rf ./output
    tResult=$($cBin/vid-tag -vv -e tzevent MVI_0107.MP4 2>&1)
    if [[ $? -ne 0 ]]; then
        fail "$LINENO vid-tag run failed: $tResult"
        if [[ -n "$tSavedTZ" ]]; then export TZ="$tSavedTZ"; else unset TZ; fi
        return 0
    fi

    tFile="./output/2016-11-20_tzevent_TP_MVI_0107.MP4"
    assertTrue "$LINENO output file exists" "[ -f $tFile ]"
    if [[ ! -f "$tFile" ]]; then
        if [[ -n "$tSavedTZ" ]]; then export TZ="$tSavedTZ"; else unset TZ; fi
        return 0
    fi

    tExif=$(exiftool "$tFile" 2>&1)

    # ----- All seven date fields must show the converted local time -----
    assertContains "$LINENO DateTimeOriginal" "$tExif" \
        "Date/Time Original              : 2016:11:20 15:20:59"
    assertContains "$LINENO CreateDate" "$tExif" \
        "Create Date                     : 2016:11:20 15:20:59"
    assertContains "$LINENO ModifyDate" "$tExif" \
        "Modify Date                     : 2016:11:20 15:20:59"
    assertContains "$LINENO TrackCreateDate" "$tExif" \
        "Track Create Date               : 2016:11:20 15:20:59"
    assertContains "$LINENO TrackModifyDate" "$tExif" \
        "Track Modify Date               : 2016:11:20 15:20:59"
    assertContains "$LINENO MediaCreateDate" "$tExif" \
        "Media Create Date               : 2016:11:20 15:20:59"
    assertContains "$LINENO MediaModifyDate" "$tExif" \
        "Media Modify Date               : 2016:11:20 15:20:59"

    # ----- touch log confirms the mtime command used the converted time.
    #       (File Modification Date/Time in exiftool reflects the host's
    #       system TZ and is therefore not asserted here directly.) -----
    assertContains "$LINENO touch log" "$tResult" \
        'touch -d "2016-11-20 15:20:59" "2016-11-20_tzevent_TP_MVI_0107.MP4"'

    if [[ -n "$tSavedTZ" ]]; then
        export TZ="$tSavedTZ"
    else
        unset TZ
    fi
    return 0
} # testCliTimeZoneExifSlow

# ========================================
# Full-pipeline CLI tests
#
# These tests run $cBin/vid-tag end-to-end on the three video files that
# come out of vid-tag-test-input.zip:
#
#     MVI_0107.MP4   270 MiB   Canon VIXIA HF R40,  CreateDate 2016:11:21 00:20:59
#     MVI_0110.MP4   114 MiB   Canon VIXIA HF R40,  CreateDate 2016:11:21 00:29:11
#     MVI_0746.MP4   4.2 GB    Canon VIXIA HF R800, CreateDate 2026:03:01 19:57:49
#
# Each test does its own run because tearDown wipes ./output/ between
# tests.  The MVI_0746.MP4 run includes ffmpeg-splitting a 23-minute
# 4.2 GB file into three 10-minute parts; expect the full-run tests
# to take a long time on a real machine.
#
# All asserts ignore the trailing " [NNN]" line-number markers via
# fStripLine; date asserts use only the date+time portion of exiftool
# output (no timezone) so they are portable across hosts.
# ========================================

# --------------------------------
fHelperRunFullPipeline() {
    # Wipe any previous output, then run $cBin/vid-tag with all three test
    # input files at -vv (info-level).  Stdout/stderr are stripped of
    # line-number markers and echoed back to the caller.
    if [[ ! -f MVI_0107.MP4 ]]; then
        return 1
    fi

    rm -rf ./output 2>/dev/null
    $cBin/vid-tag -vv -e testevent \
        MVI_0107.MP4 MVI_0110.MP4 MVI_0746.MP4 2>&1 | fStripLine
} # fHelperRunFullPipeline

# --------------------------------
testCliFullRunStdoutSlow() {
    # Run vid-tag against all three test-input files and verify the
    # expected log messages appear on stdout (which fLog routes to
    # stderr - merged here with 2>&1).
    local tResult

    echo -e "\tfHelperRunFullPipeline"
    tResult=$(fHelperRunFullPipeline)
    if [[ $? -ne 0 ]]; then
        fail "$LINENO Missing test files."
        return 0
    fi

    # ----- Conf save / output dir creation -----
    assertContains "$LINENO save conf"   "$tResult" \
        "Saving local config: ./vid-tag.conf (event=testevent)"
    assertContains "$LINENO output dir"  "$tResult" \
        "Created output dir: output"

    # ----- Copy phase: one Copy line per input file -----
    assertContains "$LINENO copy 0107"   "$tResult" \
        "Copy: MVI_0107.MP4 -> output/MVI_0107.MP4"
    assertContains "$LINENO copy 0110"   "$tResult" \
        "Copy: MVI_0110.MP4 -> output/MVI_0110.MP4"
    assertContains "$LINENO copy 0746"   "$tResult" \
        "Copy: MVI_0746.MP4 -> output/MVI_0746.MP4"

    # ----- Processing announcement per file -----
    assertContains "$LINENO proc 0107"   "$tResult" \
        "Processing: MVI_0107.MP4"
    assertContains "$LINENO proc 0110"   "$tResult" \
        "Processing: MVI_0110.MP4"
    assertContains "$LINENO proc 0746"   "$tResult" \
        "Processing: MVI_0746.MP4"

    # ----- Rename: input -> dated/event/photog/file pattern -----
    assertContains "$LINENO rename 0107" "$tResult" \
        "Rename: MVI_0107.MP4 -> 2016-11-21_testevent_BAR_MVI_0107.MP4"
    assertContains "$LINENO rename 0110" "$tResult" \
        "Rename: MVI_0110.MP4 -> 2016-11-21_testevent_BAR_MVI_0110.MP4"
    assertContains "$LINENO rename 0746" "$tResult" \
        "Rename: MVI_0746.MP4 -> 2026-03-01_testevent_BAR_MVI_0746.MP4"

    # ----- exiftool command-line tag values come from the conf -----
    assertContains "$LINENO set" "$tResult" \
        "Set new meta values"

    # ----- exiftool reports "1 image files updated" for each processed file -----
    assertContains "$LINENO 1 file updated" "$tResult" \
        "1 image files updated"

    # ----- touch -t with the exif CreateDate (HHMM.SS, no timezone) -----
    assertContains "$LINENO touch 0107" "$tResult" \
        'touch -d "2016-11-21 00:20:59" "2016-11-21_testevent_BAR_MVI_0107.MP4"'
    assertContains "$LINENO touch 0110" "$tResult" \
        'touch -d "2016-11-21 00:29:11" "2016-11-21_testevent_BAR_MVI_0110.MP4"'
    assertContains "$LINENO touch 0746" "$tResult" \
        'touch -d "2026-03-01 19:57:49" "2026-03-01_testevent_BAR_MVI_0746.MP4"'

    # ----- Splitting: only MVI_0746.MP4 is > 10 minutes (23:45) -----
    assertContains "$LINENO split"        "$tResult" \
        "Split 2026-03-01_testevent_BAR_MVI_0746.MP4 into 10min parts"
    assertContains "$LINENO copy exif"    "$tResult" \
        "Copy the exif data from original"

    # The TagsFromFile invocations - one per split part
    assertContains "$LINENO tags 00 part" "$tResult" \
        "exiftool -TagsFromFile 2026-03-01_testevent_BAR_MVI_0746.MP4 -all:all 2026-03-01_testevent_BAR_MVI_0746-00.mp4"

    assertContains "$LINENO tags 01 part" "$tResult" \
        "exiftool -TagsFromFile 2026-03-01_testevent_BAR_MVI_0746.MP4 -all:all 2026-03-01_testevent_BAR_MVI_0746-01.mp4"

    assertContains "$LINENO tags 02 part" "$tResult" \
        "exiftool -TagsFromFile 2026-03-01_testevent_BAR_MVI_0746.MP4 -all:all 2026-03-01_testevent_BAR_MVI_0746-02.mp4"

    # The touch - one per split part
    assertContains "$LINENO touch 00 part" "$tResult" \
        'touch -d "2026-03-01 19:57:49" 2026-03-01_testevent_BAR_MVI_0746-00.mp4'

    assertContains "$LINENO touch 01 part" "$tResult" \
        'touch -d "2026-03-01 20:07:49" 2026-03-01_testevent_BAR_MVI_0746-01.mp4'

    assertContains "$LINENO touch 02 part" "$tResult" \
        'touch -d "2026-03-01 20:17:49" 2026-03-01_testevent_BAR_MVI_0746-02.mp4'

    # ----- Final notice -----
    assertContains "$LINENO done" "$tResult" "Done."

    # ----- The two short files must NOT be split (under 10 min) -----
    if echo "$tResult" | grep -q "Split.*MVI_0107"; then
        fail "$LINENO MVI_0107 should not be split (only 1:36 long)"
    fi
    if echo "$tResult" | grep -q "Split.*MVI_0110"; then
        fail "$LINENO MVI_0110 should not be split (only 0:41 long)"
    fi
    return 0
} # testCliFullRunStdoutSlow

# --------------------------------
testCliFullRunOutputFilesSlow() {
    # Run vid-tag and verify all expected files end up in ./output/
    # with the expected (dated/event/photog/file pattern) names.

    echo -e "\tfHelperRunFullPipeline"
    fHelperRunFullPipeline >/dev/null
    if [[ $? -ne 0 ]]; then
        fail "$LINENO Missing test files."
        return 0
    fi
    
    # ----- The renamed primary files -----
    assertTrue "$LINENO 0107 exists" \
        "[ -f ./output/2016-11-21_testevent_BAR_MVI_0107.MP4 ]"
    assertTrue "$LINENO 0110 exists" \
        "[ -f ./output/2016-11-21_testevent_BAR_MVI_0110.MP4 ]"
    assertTrue "$LINENO 0746 exists" \
        "[ -f ./output/2026-03-01_testevent_BAR_MVI_0746.MP4 ]"

    # ----- The 4.2GB / 23:45 file is split into three 10-min parts -----
    assertTrue "$LINENO 0746-00 exists" \
        "[ -f ./output/2026-03-01_testevent_BAR_MVI_0746-00.mp4 ]"
    assertTrue "$LINENO 0746-01 exists" \
        "[ -f ./output/2026-03-01_testevent_BAR_MVI_0746-01.mp4 ]"
    assertTrue "$LINENO 0746-02 exists" \
        "[ -f ./output/2026-03-01_testevent_BAR_MVI_0746-02.mp4 ]"

    # ----- The original (un-renamed) names must NOT remain in ./output/ -----
    assertFalse "$LINENO no orig 0107" \
        "[ -f ./output/MVI_0107.MP4 ]"
    assertFalse "$LINENO no orig 0110" \
        "[ -f ./output/MVI_0110.MP4 ]"
    assertFalse "$LINENO no orig 0746" \
        "[ -f ./output/MVI_0746.MP4 ]"

    # ----- exiftool's "_original" backup files are removed by vid-tag -----
    if ls ./output/*_original 2>/dev/null | grep -q .; then
        fail "$LINENO _original backups not cleaned up"
    fi

    # ----- The two short files (MVI_0107 / MVI_0110) must NOT be split -----
    if ls ./output/2016-11-21_testevent_BAR_MVI_0107-*.mp4 2>/dev/null | grep -q .; then
        fail "$LINENO MVI_0107 should not be split"
    fi
    if ls ./output/2016-11-21_testevent_BAR_MVI_0110-*.mp4 2>/dev/null | grep -q .; then
        fail "$LINENO MVI_0110 should not be split"
    fi
    return 0
} # testCliFullRunOutputFilesSlow

# --------------------------------
testCliFullRunExifSlow() {
    # Verify the exif tags written to the renamed MVI_0107 output file.
    local tExif
    local tFile
    local tMeta
    local tPart
    local tValue

    echo -e "\tfHelperRunFullPipeline"
    fHelperRunFullPipeline >/dev/null
    if [[ $? -ne 0 ]]; then
        fail "$LINENO Missing test files."
        return 0
    fi

    echo -e "\tMVI_0107.MP4" 1>&2
    
    tFile="./output/2016-11-21_testevent_BAR_MVI_0107.MP4"
    assertTrue "$LINENO file exists" "[ -f $tFile ]"

    tExif=$(exiftool "$tFile" 2>&1)

    # ----- Tags written by vid-tag (from the testevent / com config) -----
    assertContains "$LINENO Title"      "$tExif" \
        "Title                           : 2016-11-21 Mon, Redwood City, This is a test title, by Bruce Rafnel."
    assertContains "$LINENO Caption"    "$tExif" \
        "Caption                         : This photo or video may be downloaded and used freely"
    assertContains "$LINENO Description" "$tExif" \
        "Description                     : This photo or video may be downloaded and used freely"
    assertContains "$LINENO ImageDesc"  "$tExif" \
        "Image Description               : This photo or video may be downloaded and used freely"
    assertContains "$LINENO Caption CC" "$tExif" \
        "https://creativecommons.org/licenses/by-nc/4.0/"
    assertContains "$LINENO Keywords"   "$tExif" \
        "Keywords                        : PBP,Protest"
    assertContains "$LINENO Copyright"  "$tExif" \
        "Copyright                       : Copyright Bruce Rafnel 2026"
    assertContains "$LINENO Artist"     "$tExif" \
        "Artist                          : Copyright Bruce Rafnel 2026"
    assertContains "$LINENO Author"     "$tExif" \
        "Author                          : Bruce Rafnel"

    # ----- Original exif dates from the source must be preserved -----
    assertContains "$LINENO DateTimeOriginal" "$tExif" \
        "Date/Time Original              : 2016:11:21 00:20:58"
    assertContains "$LINENO CreateDate" "$tExif" \
        "Create Date                     : 2016:11:21 00:20:59"
    assertContains "$LINENO ModifyDate" "$tExif" \
        "Modify Date                     : 2016:11:21 00:20:59"

    # ----- File-system mtime aligned with the exif CreateDate.
    #       Match only date+time, not timezone (timezone varies by host). -----
    assertContains "$LINENO File mod date" "$tExif" \
        "File Modification Date/Time     : 2016:11:21 00:20:59"

    # ----- Original camera info is preserved (not overwritten) -----
    assertContains "$LINENO Camera Model" "$tExif" \
        "Camera Model Name               : Canon VIXIA HF R40"
    assertContains "$LINENO Make"        "$tExif" \
        "Make                            : Canon"

    # --------------------------------
    echo -e "\tMVI0110.MP4" 1>&2
    # Verify the exif tags written to the renamed MVI_0110 output file.
    # Same camera as 0107 but a different per-file CreateDate.

    tFile="./output/2016-11-21_testevent_BAR_MVI_0110.MP4"
    assertTrue "$LINENO file exists" "[ -f $tFile ]"

    tExif=$(exiftool "$tFile" 2>&1)

    # ----- Tags written by vid-tag -----
    assertContains "$LINENO Title"      "$tExif" \
        "Title                           : 2016-11-21 Mon, Redwood City, This is a test title, by Bruce Rafnel."
    assertContains "$LINENO Caption"    "$tExif" \
        "Caption                         : This photo or video may be downloaded and used freely"
    assertContains "$LINENO Caption CC" "$tExif" \
        "https://creativecommons.org/licenses/by-nc/4.0/"
    assertContains "$LINENO Keywords"   "$tExif" \
        "Keywords                        : PBP,Protest"
    assertContains "$LINENO Copyright"  "$tExif" \
        "Copyright                       : Copyright Bruce Rafnel 2026"
    assertContains "$LINENO Artist"     "$tExif" \
        "Artist                          : Copyright Bruce Rafnel 2026"
    assertContains "$LINENO Author"     "$tExif" \
        "Author                          : Bruce Rafnel"

    # ----- Original exif dates from the source must be preserved -----
    assertContains "$LINENO DateTimeOriginal" "$tExif" \
        "Date/Time Original              : 2016:11:21 00:29:10"
    assertContains "$LINENO CreateDate" "$tExif" \
        "Create Date                     : 2016:11:21 00:29:11"
    assertContains "$LINENO ModifyDate" "$tExif" \
        "Modify Date                     : 2016:11:21 00:29:11"

    # --------------------------------
    echo -e "\tMVI_0746.MP4" 1>&2
    # Verify the exif tags written to the renamed MVI_0746 output file
    # (the 4.2GB master, before splitting).

    tFile="./output/2026-03-01_testevent_BAR_MVI_0746.MP4"
    assertTrue "$LINENO file exists" "[ -f $tFile ]"

    tExif=$(exiftool "$tFile" 2>&1)

    # ----- Tags written by vid-tag.  Note Sun (Mar 1, 2026 was a Sunday). -----
    assertContains "$LINENO Title"      "$tExif" \
        "Title                           : 2026-03-01 Sun, Redwood City, This is a test title, by Bruce Rafnel."
    assertContains "$LINENO Caption"    "$tExif" \
        "Caption                         : This photo or video may be downloaded and used freely"
    assertContains "$LINENO Caption CC" "$tExif" \
        "https://creativecommons.org/licenses/by-nc/4.0/"
    assertContains "$LINENO Keywords"   "$tExif" \
        "Keywords                        : PBP,Protest"
    assertContains "$LINENO Copyright"  "$tExif" \
        "Copyright                       : Copyright Bruce Rafnel 2026"
    assertContains "$LINENO Artist"     "$tExif" \
        "Artist                          : Copyright Bruce Rafnel 2026"
    assertContains "$LINENO Author"     "$tExif" \
        "Author                          : Bruce Rafnel"

    # ----- Original exif dates from the source must be preserved -----
    assertContains "$LINENO DateTimeOriginal" "$tExif" \
        "Date/Time Original              : 2026:03:01 11:57:48"
    assertContains "$LINENO CreateDate" "$tExif" \
        "Create Date                     : 2026:03:01 19:57:49"
    assertContains "$LINENO ModifyDate" "$tExif" \
        "Modify Date                     : 2026:03:01 19:57:49"

    # ----- File-system mtime -----
    assertContains "$LINENO File mod date" "$tExif" \
        "File Modification Date/Time     : 2026:03:01 19:57:49"

    # ----- Original camera info preserved (different camera from 0107/0110) -----
    assertContains "$LINENO Camera Model" "$tExif" \
        "Camera Model Name               : Canon VIXIA HF R800"
    assertContains "$LINENO Make"        "$tExif" \
        "Make                            : Canon"

    # --------------------------------
    echo -en "\tsplit " 1>&2
    # Verify the exif tags on the three 10-minute split parts.  Each
    # part has metadata copied from the parent via -TagsFromFile, but
    # excluding FileName, Title/Caption/Copyright/Artist/Author/Keywords
    # (those come from the per-part tag-set), all "*date*" fields
    # (preserved from the split itself), and MakerNotes.
    #
    # Note that exiftool's -TagsFromFile then fills the kept tags
    # (Title, Caption, etc.) FROM the parent, so the per-part files
    # end up carrying the same vid-tag-written values as the parent.

    for tPart in 00 01 02; do
        echo -en "$tPart " 1>&2
        tFile="./output/2026-03-01_testevent_BAR_MVI_0746-${tPart}.mp4"
        assertTrue "$LINENO part $tPart exists" "[ -f $tFile ]"
        if [[ ! -f $tFile ]]; then
            continue
        fi

        tExif=$(exiftool "$tFile" 2>&1)

        # Title/Caption/Keywords/Copyright/Artist/Author copied from parent.
        tMeta=$(echo "$tExif" | grep '^Title ')
        assertContains "$LINENO part $tPart Title" "$tMeta" "Title "
        assertContains "$LINENO part $tPart Title" "$tMeta" \
                       " : 2026-03-01 Sun, Redwood City, This is a test title, by Bruce Rafnel."
        tMeta=$(echo "$tExif" | grep '^Caption ')
        assertContains "$LINENO part $tPart Caption" "$tMeta" "Caption "
        assertContains "$LINENO part $tPart Caption" "$tMeta" \
                       " : This photo or video may be downloaded and used freely"
        
        tMeta=$(echo "$tExif" | grep '^Keywords ')
        assertContains "$LINENO part $tPart Keywords" "$tMeta" "Keywords"
        assertContains "$LINENO part $tPart Keywords" "$tMeta" \
                       " : PBP,Protest"
        
        tMeta=$(echo "$tExif" | grep '^Copyright ')
        assertContains "$LINENO part $tPart Copyright" "$tMeta" "Copyright "
        assertContains "$LINENO part $tPart Copyright" "$tMeta" \
                       " : Copyright Bruce Rafnel 2026"
        
        tMeta=$(echo "$tExif" | grep '^Artist ')
        assertContains "$LINENO part $tPart Artist" "$tMeta" "Artist "
        assertContains "$LINENO part $tPart Artist" "$tMeta" \
                       " : Copyright Bruce Rafnel 2026"

        tMeta=$(echo "$tExif" | grep '^Author ')
        assertContains "$LINENO part $tPart Author" "$tMeta" "Author "
        assertContains "$LINENO part $tPart Author" "$tMeta" \
                       " : Bruce Rafnel"
    done
    echo -e " " 1>&2

    return 0
} # testCliFullRunExifSlow

# ========================================
# Function-level tests (vid-tag.inc)
# ========================================

# --------------------------------
testInitialConfig() {
    # Verify the test environment is sane.  setUp forces cName="vid-tag"
    # so the function-level conf tests behave consistently with the
    # real script.  MVI_*.MP4 inputs are only required for the *Slow
    # tests, so they are not asserted here.
    assertEquals "$LINENO cName"      "vid-tag"      "$cName"
    assertNotNull "$LINENO cBin"      "$cBin"
    assertTrue   "$LINENO cBin dir"     "[ -d $cBin ]"
    assertTrue   "$LINENO vid-tag"      "[ -x $cBin/vid-tag ]"
    assertTrue   "$LINENO vid-tag.inc"  "[ -f $cBin/vid-tag.inc ]"
    assertTrue   "$LINENO bash-com.inc" "[ -f $cBin/bash-com.inc ]"
    assertTrue   "$LINENO test conf"   "[ -f vid-tag.conf.original ]"
    return 0
} # testInitialConfig

# --------------------------------
testConvertDate() {
    fConvertDate "2024:06:15 10:30:00"

    assertEquals "$LINENO short" "2024-06-15"          "$gFileDateShort"
    assertEquals "$LINENO long"  "2024-06-15 Sat"      "$gFileDateLong"
    assertEquals "$LINENO full"  "2024-06-15_10:30:00" "$gFileDateFull"
    assertEquals "$LINENO touch" "202406151030.00"     "$gFileDateTouch"
    return 0
} # testConvertDate

# --------------------------------
testConvertDate_TestFiles() {
    # Replicate the dates that fReadFileDate would produce for the three
    # test-input files.  Exiftool CreateDates per the input spec:
    #   MVI_0107.MP4  2016:11:21 00:20:59  (Mon)
    #   MVI_0110.MP4  2016:11:21 00:29:11  (Mon)
    #   MVI_0746.MP4  2026:03:01 19:57:49  (Sun)

    # MVI_0107.MP4
    fConvertDate "2016:11:21 00:20:59"
    assertEquals "$LINENO 0107 short" "2016-11-21"          "$gFileDateShort"
    assertEquals "$LINENO 0107 long"  "2016-11-21 Mon"      "$gFileDateLong"
    assertEquals "$LINENO 0107 touch" "201611210020.59"     "$gFileDateTouch"

    # MVI_0110.MP4
    fConvertDate "2016:11:21 00:29:11"
    assertEquals "$LINENO 0110 short" "2016-11-21"          "$gFileDateShort"
    assertEquals "$LINENO 0110 touch" "201611210029.11"     "$gFileDateTouch"

    # MVI_0746.MP4
    fConvertDate "2026:03:01 19:57:49"
    assertEquals "$LINENO 0746 short" "2026-03-01"          "$gFileDateShort"
    assertEquals "$LINENO 0746 long"  "2026-03-01 Sun"      "$gFileDateLong"
    assertEquals "$LINENO 0746 touch" "202603011957.49"     "$gFileDateTouch"
    return 0
} # testConvertDate_TestFiles

# --------------------------------
testConvertTimeZone_NoConversion() {
    # When gpTimeZone is empty or "local", the input must be returned
    # verbatim with no shelling out to date(1).
    local tResult

    gpTimeZone=""
    tResult=$(fConvertTimeZone "2026:05:02 01:00:00")
    assertEquals "$LINENO empty"     "2026:05:02 01:00:00" "$tResult"

    gpTimeZone="local"
    tResult=$(fConvertTimeZone "2026:05:02 01:00:00")
    assertEquals "$LINENO local"     "2026:05:02 01:00:00" "$tResult"

    # Round-trip a zero-padded date too
    gpTimeZone=""
    tResult=$(fConvertTimeZone "2016:11:21 00:20:59")
    assertEquals "$LINENO 0107"      "2016:11:21 00:20:59" "$tResult"
    return 0
} # testConvertTimeZone_NoConversion

# --------------------------------
testConvertTimeZone_Convert() {
    # Reproduce the spec example exactly:
    #   gpTimeZone="utc-1"
    #   input  "2026-05-02 01:00:00" (in UTC-1, i.e. one hour AHEAD of UTC)
    #   output "2026-05-01 17:00:00" (in PDT, UTC-7)
    # Pin TZ for portability across hosts.
    local tResult
    local tSavedTZ="${TZ-}"

    export TZ="America/Los_Angeles"

    gpTimeZone="utc-1"
    tResult=$(fConvertTimeZone "2026:05:02 01:00:00")
    assertEquals "$LINENO spec example" "2026:05:01 17:00:00" "$tResult"

    # Same input, uppercase prefix.
    gpTimeZone="UTC-1"
    tResult=$(fConvertTimeZone "2026:05:02 01:00:00")
    assertEquals "$LINENO uppercase"    "2026:05:01 17:00:00" "$tResult"

    # MVI_0107-style date.  CreateDate "2016:11:21 00:20:59" interpreted
    # as utc-1 (UTC+1) is "2016:11:20 23:20:59 UTC" -> PST (UTC-8 in Nov)
    # is "2016:11:20 15:20:59".
    gpTimeZone="utc-1"
    tResult=$(fConvertTimeZone "2016:11:21 00:20:59")
    assertEquals "$LINENO 0107 utc-1"   "2016:11:20 15:20:59" "$tResult"

    # Restore env TZ
    if [[ -n "$tSavedTZ" ]]; then
        export TZ="$tSavedTZ"
    else
        unset TZ
    fi
    return 0
} # testConvertTimeZone_Convert

# --------------------------------
testConvertTimeZone_FormatVariants() {
    # Exercise every documented format variant: UTC+H, UTC-H, UTC+H:MM,
    # UTC-H:MM, with both UTC and utc.
    local tResult
    local tSavedTZ="${TZ-}"

    export TZ="America/Los_Angeles"

    # UTC+H (zone H hours BEHIND UTC).  utc+8 = UTC-08:00.
    # 2026-05-02 12:00:00 utc+8 = 2026-05-02 20:00:00 UTC = 13:00 PDT
    gpTimeZone="utc+8"
    tResult=$(fConvertTimeZone "2026:05:02 12:00:00")
    assertEquals "$LINENO utc+8"     "2026:05:02 13:00:00" "$tResult"

    # UTC-H:MM (5:30 ahead of UTC).
    # 2026-05-02 01:00:00 UTC-5:30 = 2026-05-01 19:30:00 UTC = 12:30 PDT
    gpTimeZone="UTC-5:30"
    tResult=$(fConvertTimeZone "2026:05:02 01:00:00")
    assertEquals "$LINENO UTC-5:30"  "2026:05:01 12:30:00" "$tResult"

    # UTC+H:MM (3:45 behind UTC).
    # 2026-05-02 12:00:00 UTC+3:45 = 2026-05-02 15:45:00 UTC = 08:45 PDT
    gpTimeZone="UTC+3:45"
    tResult=$(fConvertTimeZone "2026:05:02 12:00:00")
    assertEquals "$LINENO UTC+3:45"  "2026:05:02 08:45:00" "$tResult"

    # Two-digit H, no minutes.
    # 2026-05-02 12:00:00 utc-12 = 2026-05-02 00:00:00 UTC = 2026-05-01 17:00 PDT
    gpTimeZone="utc-12"
    tResult=$(fConvertTimeZone "2026:05:02 12:00:00")
    assertEquals "$LINENO utc-12"    "2026:05:01 17:00:00" "$tResult"

    if [[ -n "$tSavedTZ" ]]; then
        export TZ="$tSavedTZ"
    else
        unset TZ
    fi
    return 0
} # testConvertTimeZone_FormatVariants

# --------------------------------
testConvertTimeZone_BadFormat() {
    # Anything that is not empty, "local", or matches UTC[+-]H[:MM]
    # should trigger fError.  Capture in a subshell because fError exits.
    local tResult

    gpTimeZone="garbage"
    tResult=$( (fConvertTimeZone "2026:05:02 01:00:00") 2>&1 )
    assertContains "$LINENO garbage"   "$tResult" "Invalid TimeZone"

    gpTimeZone="UTC"
    tResult=$( (fConvertTimeZone "2026:05:02 01:00:00") 2>&1 )
    assertContains "$LINENO no-offset" "$tResult" "Invalid TimeZone"

    gpTimeZone="UTC1"
    tResult=$( (fConvertTimeZone "2026:05:02 01:00:00") 2>&1 )
    assertContains "$LINENO no-sign"   "$tResult" "Invalid TimeZone"

    # Single-digit minutes are not valid
    gpTimeZone="UTC-1:5"
    tResult=$( (fConvertTimeZone "2026:05:02 01:00:00") 2>&1 )
    assertContains "$LINENO bad-mins"  "$tResult" "Invalid TimeZone"
    return 0
} # testConvertTimeZone_BadFormat

# --------------------------------
testReadFileDate_TimeZoneSlow() {
    # fReadFileDate is the integration point that calls fConvertTimeZone
    # before fConvertDate.  Verify gFileDate (and the gFileDate* outputs
    # of fConvertDate) reflect the converted local time when gpTimeZone
    # is set, and the original exiftool value when gpTimeZone is empty.
    #
    # NOTE: Slow - requires the MVI_0107.MP4 input file.
    local tSavedTZ="${TZ-}"

    if [[ ! -f MVI_0107.MP4 ]]; then
        fail "$LINENO Missing test files."
        return 0
    fi

    export TZ="America/Los_Angeles"

    # ---- Baseline: no conversion ----
    gpTimeZone=""
    fReadFileDate "MVI_0107.MP4"
    assertEquals "$LINENO baseline gFileDate"  "2016:11:21 00:20:59" "$gFileDate"
    assertEquals "$LINENO baseline short"      "2016-11-21"          "$gFileDateShort"

    # ---- With conversion: utc-1 shifts MVI_0107 back by 9 hours ----
    gpTimeZone="utc-1"
    fReadFileDate "MVI_0107.MP4"
    assertEquals "$LINENO tz gFileDate" "2016:11:20 15:20:59" "$gFileDate"
    assertEquals "$LINENO tz short"     "2016-11-20"          "$gFileDateShort"
    assertEquals "$LINENO tz long"      "2016-11-20 Sun"      "$gFileDateLong"
    assertEquals "$LINENO tz full"      "2016-11-20_15:20:59" "$gFileDateFull"
    assertEquals "$LINENO tz touch"     "201611201520.59"     "$gFileDateTouch"

    if [[ -n "$tSavedTZ" ]]; then
        export TZ="$tSavedTZ"
    else
        unset TZ
    fi
    return 0
} # testReadFileDate_TimeZoneSlow

# --------------------------------
testApplyPattern() {
    local tResult

    # Set up the globals fApplyPattern reads
    gFileDateShort="2024-06-15"
    gFileDateLong="2024-06-15 Sat"
    gFileDateFull="2024-06-15_10:30:00"
    gpEventId="summer_camp"
    gpEventTitle="Summer Camp 2024"
    gpNameShort="JD"
    gpNameLong="Jane Doe"
    gpEventCity="Springfield"

    #-----
    tResult=$(fApplyPattern '%d_%e_%p_%f' 'clip001.mp4')
    assertEquals "$LINENO file-pat" \
        "2024-06-15_summer_camp_JD_clip001.mp4" "$tResult"

    #-----
    tResult=$(fApplyPattern '%D, %c, %E, by %P.' 'clip001.mp4')
    assertEquals "$LINENO title-pat" \
        "2024-06-15 Sat, Springfield, Summer Camp 2024, by Jane Doe." "$tResult"

    #-----
    # %T expands to gFileDateFull
    tResult=$(fApplyPattern '%T' 'x.mp4')
    assertEquals "$LINENO %T" "2024-06-15_10:30:00" "$tResult"

    # Empty pattern → empty string
    tResult=$(fApplyPattern '' 'x.mp4')
    assertEquals "$LINENO empty" "" "$tResult"

    # Pattern with no tokens passes through unchanged
    tResult=$(fApplyPattern 'literal-text' 'x.mp4')
    assertEquals "$LINENO literal" "literal-text" "$tResult"
    return 0
} # testApplyPattern

# --------------------------------
testApplyPattern_AllTokens() {
    local tResult

    gFileDateShort="2026-03-01"
    gFileDateLong="2026-03-01 Sun"
    gFileDateFull="2026-03-01_19:57:49"
    gpEventId="testevent"
    gpEventTitle="This is a test title"
    gpNameShort="BAR"
    gpNameLong="Bruce Rafnel"
    gpEventCity="Redwood City"

    # Reproduce the %D, %c, %E, by %P. title pattern from the conf
    tResult=$(fApplyPattern '%D, %c, %E, by %P.' 'MVI_0746.MP4')
    assertEquals "$LINENO 0746 title" \
        "2026-03-01 Sun, Redwood City, This is a test title, by Bruce Rafnel." \
        "$tResult"

    # Reproduce the %d_%e_%p_%f file-name pattern
    tResult=$(fApplyPattern '%d_%e_%p_%f' 'MVI_0746.MP4')
    assertEquals "$LINENO 0746 file" \
        "2026-03-01_testevent_BAR_MVI_0746.MP4" "$tResult"
    return 0
} # testApplyPattern_AllTokens

# --------------------------------
testLoadConf() {
    # fLoadConf sources the bash-include conf and copies each conf-file
    # variable to the corresponding internal gp* global.
    local tConf

    tConf="$cTmp1"

    cat >"$tConf" <<'CONF'
Caption="Test Caption"
Copyright="Copyright NAME YYYY"
FilePat="%d_%e_%p_%f"
NameLong="Test Photographer"
NameShort="TP"
TitlePat="%D, %c, %E, by %P."
Event="test_event"
City="Test Village"
Title="Test Event Title"
Keyword="PBP,Protest"
CONF

    # Point gpConfLocal at our temp file and load.
    gpConfLocal="$tConf"
    fLoadConf

    assertEquals "$LINENO Caption"    "Test Caption"        "$gpCaption"
    assertEquals "$LINENO Copyright"  "Copyright NAME YYYY" "$gpCopyright"
    assertEquals "$LINENO NameLong"   "Test Photographer"   "$gpNameLong"
    assertEquals "$LINENO NameShort"  "TP"                  "$gpNameShort"
    assertEquals "$LINENO FilePat"    "%d_%e_%p_%f"         "$gpFilePat"
    assertEquals "$LINENO TitlePat"   "%D, %c, %E, by %P."  "$gpTitlePat"
    assertEquals "$LINENO Event"      "test_event"          "$gpEventId"
    assertEquals "$LINENO Title"      "Test Event Title"    "$gpEventTitle"
    assertEquals "$LINENO City"       "Test Village"        "$gpEventCity"
    assertEquals "$LINENO Keyword"    "PBP,Protest"         "$gpEventKeyword"

    # Restore
    gpConfLocal="./vid-tag.conf"
    return 0
} # testLoadConf

# --------------------------------
testLoadConf_Extras() {
    # Extra["FILE"]="..." lines in the conf must populate gExtraMap
    # with exact, case-sensitive keys.
    local tConf="$cTmp1"

    cat > "$tConf" << 'CONF'
Caption="Some caption"
Event="testevent"
City="Redwood City"
Extra["MVI_0107.MP4"]="Blocking diagram one"
Extra["MVI_0110.MP4"]="Blocking diagram two"
Extra["MVI_0746.MP4"]="Service fragment"
CONF

    gpConfLocal="$tConf"
    declare -gA gExtraMap=()

    fLoadConf >/dev/null 2>&1

    # Map populated with all three entries, exact-match keys.
    assertEquals "$LINENO map size" "3" "${#gExtraMap[@]}"
    assertEquals "$LINENO 0107"     "Blocking diagram one" \
        "${gExtraMap[MVI_0107.MP4]:-}"
    assertEquals "$LINENO 0110"     "Blocking diagram two" \
        "${gExtraMap[MVI_0110.MP4]:-}"
    assertEquals "$LINENO 0746"     "Service fragment" \
        "${gExtraMap[MVI_0746.MP4]:-}"

    gpConfLocal="./vid-tag.conf"
    return 0
} # testLoadConf_Extras

# --------------------------------
testLoadConf_ExtrasExactMatch() {
    # Extras keys must match the file basename exactly: case
    # differences, partial matches, and extension changes must NOT
    # match.
    local tConf="$cTmp1"

    cat > "$tConf" << 'CONF'
Event="testevent"
Extra["MVI_0107.MP4"]="One"
CONF

    gpConfLocal="$tConf"
    declare -gA gExtraMap=()

    fLoadConf >/dev/null 2>&1

    # Exact key hits
    assertEquals "$LINENO exact"   "One" "${gExtraMap[MVI_0107.MP4]:-}"

    # Case mismatch on filename: NOT a match
    assertEquals "$LINENO lowercase miss" "" "${gExtraMap[mvi_0107.mp4]:-}"
    # Case mismatch on extension: NOT a match
    assertEquals "$LINENO ext-case miss"  "" "${gExtraMap[MVI_0107.mp4]:-}"
    # Partial: NOT a match
    assertEquals "$LINENO partial miss"   "" "${gExtraMap[MVI_0107]:-}"
    # Different file: NOT a match
    assertEquals "$LINENO other miss"     "" "${gExtraMap[MVI_0108.MP4]:-}"

    gpConfLocal="./vid-tag.conf"
    return 0
} # testLoadConf_ExtrasExactMatch

# --------------------------------
testLoadConf_MissingFile() {
    # When gpConfLocal points at a non-existent file, fLoadConf must
    # create it (with the current defaults) via fSaveConf.
    local tConf="$Tmp/no-such-conf.conf"

    gpConfLocal="$tConf"
    rm -f "$tConf"
    gpEventId="testevent"
    # Defaults are otherwise whatever setUp left them; that's fine.

    fLoadConf >/dev/null 2>&1
    assertTrue "$LINENO rc"              "[ $? -eq 0 ]"
    assertTrue "$LINENO file created"    "[ -f $tConf ]"

    # Conf must be valid bash.
    bash -n "$tConf"
    assertTrue "$LINENO valid bash"      "[ $? -eq 0 ]"

    # Event= line uses the gpEventId value.
    grep -q '^Event="testevent"' "$tConf"
    assertTrue "$LINENO Event in conf"   "[ $? -eq 0 ]"

    rm -f "$tConf"
    gpConfLocal="./vid-tag.conf"
    return 0
} # testLoadConf_MissingFile

# --------------------------------
testLoadConf_BadSyntax() {
    # A conf file with bash syntax errors must trigger fError.
    local tConf="$cTmp1"
    local tResult

    # Unterminated double-quote string → bash -n fails.
    echo 'Caption="never closed' > "$tConf"

    gpConfLocal="$tConf"

    tResult=$( (fLoadConf) 2>&1 )
    assertContains "$LINENO syntax err" "$tResult" "Syntax error"

    gpConfLocal="./vid-tag.conf"
    return 0
} # testLoadConf_BadSyntax

# --------------------------------
testLoadConf_PreservesDefaults() {
    # Values that are not in the conf file must keep their pre-load
    # defaults.  Only the keys present in the file are overridden.
    local tConf="$cTmp1"

    cat > "$tConf" << 'CONF'
Caption="Only Caption Set"
CONF

    gpConfLocal="$tConf"
    gpCopyright="DefaultCopyright"
    gpNameLong="DefaultName"
    gpEventId="defaultevent"

    fLoadConf >/dev/null 2>&1

    assertEquals "$LINENO caption read"      "Only Caption Set"  "$gpCaption"
    assertEquals "$LINENO copyright kept"    "DefaultCopyright"  "$gpCopyright"
    assertEquals "$LINENO name-long kept"    "DefaultName"       "$gpNameLong"
    assertEquals "$LINENO event kept"        "defaultevent"      "$gpEventId"

    gpConfLocal="./vid-tag.conf"
    return 0
} # testLoadConf_PreservesDefaults

# --------------------------------
testSaveConf() {
    # fSaveConf writes the current gp* / gExtraMap values to
    # gpConfLocal in bash-include format.  The file must be valid bash
    # and round-trip back through fLoadConf.
    local tConf

    tConf="$cTmp1"
    rm -f "$tConf"

    gpConfLocal="$tConf"
    gpEventId="saveconftest"
    gpCaption="Saved Caption"
    gpCopyright="Saved (c) 2030"
    gpFilePat="%d_%e_%f"
    gpTitlePat="%D %E by %P"
    gpNameLong="Saver Name"
    gpNameShort="SN"
    gpEventTitle="Saved Title"
    gpEventCity="Saved City"
    gpEventKeyword="kw1,kw2"
    gpEventFileList="some.mp4 other.mp4"

    fSaveConf >/dev/null 2>&1

    assertTrue "$LINENO conf created"      "[ -f $tConf ]"

    # File must be valid bash.
    bash -n "$tConf"
    assertTrue "$LINENO valid bash"        "[ $? -eq 0 ]"

    grep -q '^Caption="Saved Caption"'     "$tConf"
    assertTrue "$LINENO Caption"           "[ $? -eq 0 ]"

    grep -q '^Copyright="Saved (c) 2030"'  "$tConf"
    assertTrue "$LINENO Copyright"         "[ $? -eq 0 ]"

    grep -q '^FilePat="%d_%e_%f"'          "$tConf"
    assertTrue "$LINENO FilePat"           "[ $? -eq 0 ]"

    grep -q '^TitlePat="%D %E by %P"'      "$tConf"
    assertTrue "$LINENO TitlePat"          "[ $? -eq 0 ]"

    grep -q '^NameLong="Saver Name"'       "$tConf"
    assertTrue "$LINENO NameLong"          "[ $? -eq 0 ]"

    grep -q '^NameShort="SN"'              "$tConf"
    assertTrue "$LINENO NameShort"         "[ $? -eq 0 ]"

    grep -q '^Event="saveconftest"'        "$tConf"
    assertTrue "$LINENO Event"             "[ $? -eq 0 ]"

    grep -q '^Title="Saved Title"'         "$tConf"
    assertTrue "$LINENO Title"             "[ $? -eq 0 ]"

    grep -q '^City="Saved City"'           "$tConf"
    assertTrue "$LINENO City"              "[ $? -eq 0 ]"

    grep -q '^Keyword="kw1,kw2"'           "$tConf"
    assertTrue "$LINENO Keyword"           "[ $? -eq 0 ]"

    # The file list is not written to the conf.
    grep -q 'FileList'                     "$tConf"
    assertFalse "$LINENO no FileList"      "[ $? -eq 0 ]"

    # Restore
    gpConfLocal="./vid-tag.conf"
    return 0
} # testSaveConf

# --------------------------------
testSaveConf_RoundTrip() {
    # fSaveConf followed by fLoadConf must round-trip every value,
    # including extras with dots, spaces, and "tricky" characters.
    local tConf="$cTmp1"

    rm -f "$tConf"
    gpConfLocal="$tConf"
    gpEventId="roundtrip"
    gpCaption='Caption with "quotes" and $variable and `backticks` and \ backslash'
    gpCopyright="(c) 2030"
    gpFilePat="%d_%e"
    gpTitlePat="%D %P"
    gpNameLong="Alice Bob"
    gpNameShort="AB"
    gpEventTitle="Event Title"
    gpEventCity="City"
    gpEventKeyword="kw"
    gpTimeZone="utc-1"

    declare -gA gExtraMap=(
        ["MVI_0107.MP4"]="Diagram one"
        ["MVI_0110.MP4"]='Note with "quote" and $dollar'
    )

    fSaveConf >/dev/null 2>&1
    assertTrue "$LINENO file created" "[ -f $tConf ]"

    # File must be valid bash.
    bash -n "$tConf"
    assertTrue "$LINENO valid bash"   "[ $? -eq 0 ]"

    # Wipe globals and reload.
    gpCaption=""
    gpCopyright=""
    gpFilePat=""
    gpTitlePat=""
    gpNameLong=""
    gpNameShort=""
    gpEventId=""
    gpEventTitle=""
    gpEventCity=""
    gpEventKeyword=""
    gpTimeZone=""
    declare -gA gExtraMap=()

    fLoadConf >/dev/null 2>&1

    assertEquals "$LINENO Caption rt"   \
        'Caption with "quotes" and $variable and `backticks` and \ backslash' \
        "$gpCaption"
    assertEquals "$LINENO Copyright rt"  "(c) 2030"        "$gpCopyright"
    assertEquals "$LINENO FilePat rt"    "%d_%e"           "$gpFilePat"
    assertEquals "$LINENO TitlePat rt"   "%D %P"           "$gpTitlePat"
    assertEquals "$LINENO NameLong rt"   "Alice Bob"       "$gpNameLong"
    assertEquals "$LINENO NameShort rt"  "AB"              "$gpNameShort"
    assertEquals "$LINENO Event rt"      "roundtrip"       "$gpEventId"
    assertEquals "$LINENO Title rt"      "Event Title"     "$gpEventTitle"
    assertEquals "$LINENO City rt"       "City"            "$gpEventCity"
    assertEquals "$LINENO Keyword rt"    "kw"              "$gpEventKeyword"
    assertEquals "$LINENO TimeZone rt"   "utc-1"           "$gpTimeZone"

    # Extras round-trip
    assertEquals "$LINENO 0107 rt"   "Diagram one"  "${gExtraMap[MVI_0107.MP4]:-}"
    assertEquals "$LINENO 0110 rt"   \
        'Note with "quote" and $dollar' "${gExtraMap[MVI_0110.MP4]:-}"

    gpConfLocal="./vid-tag.conf"
    return 0
} # testSaveConf_RoundTrip

# --------------------------------
testSaveConf_NoTimeZoneWhenEmpty() {
    # When gpTimeZone is empty, fSaveConf must not emit a TimeZone= line.
    local tConf="$cTmp1"

    rm -f "$tConf"
    gpConfLocal="$tConf"
    gpEventId="notz"
    gpTimeZone=""

    fSaveConf >/dev/null 2>&1

    grep -q '^TimeZone=' "$tConf"
    assertFalse "$LINENO no TimeZone line" "[ $? -eq 0 ]"

    gpConfLocal="./vid-tag.conf"
    return 0
} # testSaveConf_NoTimeZoneWhenEmpty


# --------------------------------
testGetOpt() {
    # Drive fGetOpt directly and verify each option lands in the right gp*
    fGetOpt -e SomeEvent -c "Town" -C "Cap" -E "Long" -f "%d_%f" \
            -k "k1,k2" -p "AB" -P "Alice B" -R "(c) 2030" \
            -t "%D by %P" -z "utc-1" -n

    assertEquals "$LINENO -e"  "someevent"   "$gpEventId"
    assertEquals "$LINENO -c"  "Town"        "$gpEventCity"
    assertEquals "$LINENO -C"  "Cap"         "$gpCaption"
    assertEquals "$LINENO -E"  "Long"        "$gpEventTitle"
    assertEquals "$LINENO -f"  "%d_%f"       "$gpFilePat"
    assertEquals "$LINENO -k"  "k1,k2"       "$gpEventKeyword"
    assertEquals "$LINENO -p"  "AB"          "$gpNameShort"
    assertEquals "$LINENO -P"  "Alice B"     "$gpNameLong"
    assertEquals "$LINENO -R"  "(c) 2030"    "$gpCopyright"
    assertEquals "$LINENO -t"  "%D by %P"    "$gpTitlePat"
    assertEquals "$LINENO -z"  "utc-1"       "$gpTimeZone"
    assertEquals "$LINENO -n"  "1"           "$gpNoExec"
    return 0
} # testGetOpt

# --------------------------------
testGetOpt_FileList() {
