    fGetOpt -e evt fileA.mp4 fileB.mp4 fileC.mp4
    assertEquals "$LINENO file-list" \
        "fileA.mp4 fileB.mp4 fileC.mp4" "$gpEventFileList"
    return 0
} # testGetOpt_FileList

