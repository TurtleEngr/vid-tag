#!/usr/bin/env bash
# $Source: /repo/video.cvs/studio/probonophoto/label/vid-tag.test,v $
# $Revision: 1.10 $ $Date: 2026/04/29 18:27:22 $ GMT
set -u

export cVer=1.1

# --------------------------------
fUsageTest() {
    # Quick help, run this:
    # vid-tag -h

    local pStyle="${1:-usage}"

    case $pStyle in
        short | usage | man | long | text | md)
            fComUsage -f $cBin/$cName -s $pStyle
            ;;
        html)
            fComUsage -f $cBin/$cName -s $pStyle -t "$cName Usage"
            ;;
        *)
            fComUsage -f $cBin/$cName -s short
            ;;
    esac
    exit 1

    # POD Syntax: https://perldoc.perl.org/perlpod
    # shellcheck disable=SC2317
    cat <<EOF >/dev/null
=pod

=for text ========================================

=for html <hr/>

=head1 NAME vid-tag.test

Test vid-tag

=head1 SYNOPSIS

    vid-tag.test [-h] [-h pStyle]
    vid-tag.test -T list [-v] [-d]
    vid-tag.test -T all [-v] [-d]
    vid-tag.test -T cli [-v] [-d]
    vid-tag.test -T not-cli [-v] [-d]
    vid-tag.test -T com [-v] [-d]
    vid-tag.test -T "pTest pTest..." [-v] [-d]

=head1 DESCRIPTION

Run unit and integration tests against vid-tag and vid-tag.inc.

The test data archive C<vid-tag-test-input.zip> must exist in the
current directory; it is unzipped during oneTimeSetUp and supplies
three video files plus a sample C<vid-tag.conf>.

=head1 OPTIONS

=over 4

=item B<-T "pTest">

Run the unit test functions in this script.

"B<-T all>" runs all functions that begin with "test".

"B<-T cli>" runs all functions that begin with "testCli".

"B<-T not-cli>" runs all functions that begin with "test", but not
"testCli".

"B<-T list>" lists all test function names.

"B<-T com>" runs all tests for bash-com.inc.

=back

=head1 RETURN VALUE

0 on success; non-zero on error.

=head1 ERRORS

Look for the assert errors.

=head1 FILES

    vid-tag
    vid-tag.inc
    vid-tag.test - this file
    vid-tag-test-input.zip - input files
    bash-com.inc
    bash-com.test
    shunit2.1

=head1 SEE ALSO

Required programs: bash, exiftool, git-config, ffmpeg, sed

=head1 AUTHOR

Turtle Engineer

=head1 HISTORY

GPLv2 (c) Copyright

$Revision: 1.10 $

=cut
EOF
} # fUsageTest

# -------------------
fSetTestGlobals() {
    fComSetGlobals
    fComCheckDeps "bash exiftool git ffmpeg sed" "cat"
    return 0
} # fSetTestGlobals

# -------------------
fStripLine() {
    # Remove the trailing " [NNN]" or "[NNN](NN)" line-number marker
    # that fLog/fError appends, so tests can match message text
    # without depending on vid-tag.inc or bash-com.inc line numbers.
    sed -E 's/ \[[0-9]+\]//; s/\([0-9]+\)$//'
} # fStripLine

# ========================================
# Tests

# --------------------------------
oneTimeSetUp() {
    # gpTest=''
    echo $gpTest | grep -q 'testCli.*()' >/dev/null 2>&1
    if [[ $? -eq 0 ]]; then
        if [[ ! -f vid-tag-test-input.zip ]]; then
            fLog -p err -m "Missing: vid-tag-test-input.zip" -l $LINENO
            fUsageTest
        fi
        unzip -o vid-tag-test-input.zip >/dev/null
    fi
    
    # Create default vid-tag.conf
    cat <<EOF >vid-tag.conf
[vid-tag "com"]
	caption = This photo or video may be downloaded and used freely for non-commercial purposes or by bona fide media services, provided that the photographer and ProbonoPhoto are credited whenever it is used. (https://www.probonophoto.org/Who-We-Are/Bruce-Rafnel). The photographer retains copyright to this image. This is a CC-NC-BY-4.0 license: https://creativecommons.org/licenses/by-nc/4.0/
	copyright = Copyright Bruce Rafnel 2026
	file-pat = %d_%e_%p_%f
	name-long = Bruce Rafnel
	name-short = BAR
	title-pat = %D, %c, %E, by %P.
[vid-tag "testevent"]
	city = Redwood City
	title = This is a test title
	keyword = PBP,Protest
EOF
    # Save a pristine copy of the conf so setUp can restore it before
    # every test that mutates ./vid-tag.conf.
    if [[ -f vid-tag.conf ]]; then
        cp vid-tag.conf vid-tag.conf.original
    fi
    return 0
} # oneTimeSetUp

# --------------------------------
oneTimeTearDown() {
    rm -f vid-tag.conf.original 2>/dev/null
    return 0
} # oneTimeTearDown

# --------------------------------
setUp() {
    # Restore conf for each test (so tests run in any order)
    if [[ -f vid-tag.conf.original ]]; then
        cp vid-tag.conf.original vid-tag.conf
    fi

    # The test script's BASH_SOURCE name is "vid-tag.test", so without
    # overriding cName the function-level tests would write conf
    # sections with keys like vid-tag.test.com.caption (yielding the
    # wrong section header).  Force cName to match what the real
    # ./vid-tag script uses so fLoadConf / fSaveConf produce
    # [vid-tag "com"] / [vid-tag "<event>"] sections.
    cName="vid-tag"

    # Reset the gp* globals that fLoadConf / fApplyPattern / fValidate
    # read.  Match the defaults in fSetGlobals.
    gpEventId=""
    gpEventCity="TBD"
    gpEventTitle="TBD"
    gpEventKeyword="TBD"
    gpEventExtra=""
    gpEventFileList=""
    gpCaption="Copyright TERMS"
    gpCopyright="Copyright NAME YYYY"
    gpFilePat='%d_%e_%p_%f'
    gpTitlePat='%D, %c, %E, by %P.'
    gpNameLong="TBD"
    gpNameShort="TBD"
    gpNoExec=0
    gpVerbose=0
    gpDebug=0

    # Per-file globals
    gFile=""
    gFileDate=""
    gFileDateFull=""
    gFileDateLong=""
    gFileDateShort=""
    gFileDateTouch=""

    # Output dir constant (set by fSetGlobals normally)
    cOutputDir="output"
    gpConfLocal="./vid-tag.conf"
    return 0
} # setUp

# --------------------------------
tearDown() {
    if [[ -d ./output ]]; then
        rm -rf ./output
    fi
    return 0
} # tearDown

# ========================================
# CLI tests (test ./vid-tag binary)
# ========================================

# --------------------------------
testCliUsage() {
    local tResult

    #-----
    tResult=$(./vid-tag 2>&1)
    assertContains "$LINENO no-args usage" "$tResult" "Usage:"

    #-----
    tResult=$(./vid-tag -H short 2>&1)
    assertContains "$LINENO short 1" "$tResult" "NAME vid-tag"
    assertContains "$LINENO short 2" "$tResult" "SYNOPSIS"
    assertContains "$LINENO short 3" "$tResult" "DESCRIPTION"

    #-----
    tResult=$(./vid-tag -H long 2>&1)
    assertContains "$LINENO long.1" "$tResult" "DESCRIPTION"
    assertContains "$LINENO long.2" "$tResult" "HISTORY"

    #-----
    tResult=$(./vid-tag -H man 2>&1)
    assertContains "$LINENO man.1" "$tResult" '.IX Header "DESCRIPTION"'
    assertContains "$LINENO man.2" "$tResult" '.IX Header "HISTORY"'

    #-----
    tResult=$(./vid-tag -H html 2>&1)
    assertContains "$LINENO html.1" "$tResult" '<li><a href="#DESCRIPTION">DESCRIPTION</a></li>'
    assertContains "$LINENO html.2" "$tResult" '<h1 id="HISTORY">HISTORY</h1>'
    assertContains "$LINENO html.3" "$tResult" "<title>vid-tag Usage</title>"

    #-----
    tResult=$(./vid-tag -H md 2>&1)
    assertContains "$LINENO md.1" "$tResult" '# DESCRIPTION'
    assertContains "$LINENO md.2" "$tResult" '# HISTORY'

    #-----
    tResult=$(./vid-tag -h 2>&1)
    assertContains "$LINENO -h.1" "$tResult" "DESCRIPTION"
    assertContains "$LINENO -h.2" "$tResult" "OPTIONS"

    return 0
} # testCliUsage

# --------------------------------
testCliMissingArgs() {
    local tResult

    # vid-tag with no args at all → "Missing required options."
    tResult=$(./vid-tag 2>&1)
    assertContains "$LINENO no-args" "$tResult" "Missing required options"
    return 0
} # testCliMissingArgs

# --------------------------------
testCliMissingEventId() {
    local tResult

    # -n alone (no -e) → "Missing pEventId"
    tResult=$(./vid-tag -n 2>&1)
    assertContains "$LINENO no-e" "$tResult" "Missing pEventId"
    return 0
} # testCliMissingEventId

# --------------------------------
testCliUnknownOption() {
    local tResult

    tResult=$(./vid-tag -e testevent -Z 2>&1)
    assertContains "$LINENO unknown-opt" "$tResult" "Unknown option"
    return 0
} # testCliUnknownOption

# --------------------------------
testCliMissingOptArg() {
    local tResult

    # -c without value → "Value required"
    tResult=$(./vid-tag -e testevent -c 2>&1)
    assertContains "$LINENO no-value-c" "$tResult" "Value required"
    return 0
} # testCliMissingOptArg

# --------------------------------
testCliNoExec() {
    local tResult

    # -n + existing testevent conf (from oneTimeSetUp) → dry run
    tResult=$(./vid-tag -v -n -e testevent 2>&1)
    assertContains "$LINENO no-exec msg" "$tResult" "No-execute"
    assertContains "$LINENO no-exec conf" "$tResult" "vid-tag.conf"

    # output dir must NOT have been created
    assertFalse "$LINENO no output dir" "[ -d ./output ]"
    return 0
} # testCliNoExec

# --------------------------------
testCliNoExecCreatesNewConf() {
    local tResult

    # Remove the conf so we can verify fresh-create behavior
    rm -f ./vid-tag.conf

    tResult=$(./vid-tag -n -e brandnew 2>&1)

    # Conf should now exist
    assertTrue "$LINENO conf created" "[ -f ./vid-tag.conf ]"

    # Conf should have a [vid-tag "com"] section and a brandnew section
    grep -q '\[vid-tag "com"\]'      ./vid-tag.conf
    assertTrue "$LINENO com section"  "[ $? -eq 0 ]"

    grep -q '\[vid-tag "brandnew"\]' ./vid-tag.conf
    assertTrue "$LINENO new section"  "[ $? -eq 0 ]"
    return 0
} # testCliNoExecCreatesNewConf

# --------------------------------
testCliEventLowercase() {
    local tResult

    rm -f ./vid-tag.conf

    # gpEventId is "declare -lx", so MixedCase should become mixedcase
    tResult=$(./vid-tag -n -e MixedCASE 2>&1)

    grep -q '\[vid-tag "mixedcase"\]' ./vid-tag.conf
    assertTrue "$LINENO lowercased" "[ $? -eq 0 ]"

    grep -q '\[vid-tag "MixedCASE"\]' ./vid-tag.conf
    assertFalse "$LINENO not original case" "[ $? -eq 0 ]"
    return 0
} # testCliEventLowercase

# --------------------------------
testCliEventSpaceUnderscore() {
    rm -f ./vid-tag.conf

    # Spaces in -e are converted to underscores
    ./vid-tag -n -e "two words" >/dev/null 2>&1

    grep -q '\[vid-tag "two_words"\]' ./vid-tag.conf
    assertTrue "$LINENO space->underscore" "[ $? -eq 0 ]"
    return 0
} # testCliEventSpaceUnderscore

# --------------------------------
testCliCity() {
    ./vid-tag -n -e testevent -c "Sample City" >/dev/null 2>&1

    grep -q 'city = Sample City' ./vid-tag.conf
    assertTrue "$LINENO city saved" "[ $? -eq 0 ]"
    return 0
} # testCliCity

# --------------------------------
testCliCaption() {
    ./vid-tag -n -e testevent -C "My test caption" >/dev/null 2>&1

    grep -q 'caption = My test caption' ./vid-tag.conf
    assertTrue "$LINENO caption saved" "[ $? -eq 0 ]"
    return 0
} # testCliCaption

# --------------------------------
testCliCopyright() {
    ./vid-tag -n -e testevent -R "Copyright Foo Bar 2030" >/dev/null 2>&1

    grep -q 'copyright = Copyright Foo Bar 2030' ./vid-tag.conf
    assertTrue "$LINENO copyright saved" "[ $? -eq 0 ]"
    return 0
} # testCliCopyright

# --------------------------------
testCliEventTitle() {
    ./vid-tag -n -e testevent -E "Long Event Description" >/dev/null 2>&1

    grep -q 'title = Long Event Description' ./vid-tag.conf
    assertTrue "$LINENO event title saved" "[ $? -eq 0 ]"
    return 0
} # testCliEventTitle

# --------------------------------
testCliKeyword() {
    ./vid-tag -n -e testevent -k "kw1,kw2,kw3" >/dev/null 2>&1

    grep -q 'keyword = kw1,kw2,kw3' ./vid-tag.conf
    assertTrue "$LINENO keyword saved" "[ $? -eq 0 ]"
    return 0
} # testCliKeyword

# --------------------------------
testCliShortName() {
    ./vid-tag -n -e testevent -p ZZZ >/dev/null 2>&1

    grep -q 'name-short = ZZZ' ./vid-tag.conf
    assertTrue "$LINENO short name saved" "[ $? -eq 0 ]"
    return 0
} # testCliShortName

# --------------------------------
testCliLongName() {
    ./vid-tag -n -e testevent -P "Some Photographer" >/dev/null 2>&1

    grep -q 'name-long = Some Photographer' ./vid-tag.conf
    assertTrue "$LINENO long name saved" "[ $? -eq 0 ]"
    return 0
} # testCliLongName

# --------------------------------
testCliFilePattern() {
    ./vid-tag -n -e testevent -f '%d-%e-%f' >/dev/null 2>&1

    grep -q 'file-pat = %d-%e-%f' ./vid-tag.conf
    assertTrue "$LINENO file-pat saved" "[ $? -eq 0 ]"
    return 0
} # testCliFilePattern

# --------------------------------
testCliBadFilePattern() {
    local tResult

    # File pattern without any %tokens → fError "missing % options"
    tResult=$(./vid-tag -n -e testevent -f "no-tokens-here" 2>&1)
    assertContains "$LINENO bad file-pat" "$tResult" "missing % options"
    return 0
} # testCliBadFilePattern

# --------------------------------
testCliTitlePattern() {
    ./vid-tag -n -e testevent -t '%D %E by %P' >/dev/null 2>&1

    grep -q 'title-pat = %D %E by %P' ./vid-tag.conf
    assertTrue "$LINENO title-pat saved" "[ $? -eq 0 ]"
    return 0
} # testCliTitlePattern

# --------------------------------
testCliBadTitlePattern() {
    local tResult

    tResult=$(./vid-tag -n -e testevent -t "no tokens" 2>&1)
    assertContains "$LINENO bad title-pat" "$tResult" "missing % options"
    return 0
} # testCliBadTitlePattern

# --------------------------------
testCliExtra() {
    # The -x value typically has a leading space; git-config may either
    # strip it or quote the whole value.  Match the substantive content
    # rather than the exact spacing.
    ./vid-tag -n -e testevent -x " More info." >/dev/null 2>&1

    grep -q 'extra = .*More info\.' ./vid-tag.conf
    assertTrue "$LINENO extra saved" "[ $? -eq 0 ]"
    return 0
} # testCliExtra

# --------------------------------
testCliFileNotFound() {
    local tResult

    # Without -n, fValidate does check files; missing file → fatal
    tResult=$(./vid-tag -e testevent /no/such/file.mp4 2>&1)
    assertContains "$LINENO missing file" "$tResult" "File not found"
    return 0
} # testCliFileNotFound

# --------------------------------
testCliVerboseLevels() {
    local tDefault
    local tV
    local tVV

    # Default verbose: only warning+. The notice "No-execute" message
    # should NOT appear.
    tDefault=$(./vid-tag -n -e testevent 2>&1)
    # "No-execute" is at notice level, not visible by default
    if echo "$tDefault" | grep -q "No-execute"; then
        fail "$LINENO default level should NOT show notice"
    fi

    # -v: notice and above. "No-execute" SHOULD appear.
    tV=$(./vid-tag -v -n -e testevent 2>&1)
    assertContains "$LINENO -v shows notice" "$tV" "No-execute"

    # -vv: info and above. "Saving local config" SHOULD appear.
    tVV=$(./vid-tag -vv -n -e testevent 2>&1)
    assertContains "$LINENO -vv shows info" "$tVV" "Saving local config"
    return 0
} # testCliVerboseLevels

# --------------------------------
testCliReadsExistingConf() {
    local tResult

    # The unzipped vid-tag.conf has a [vid-tag "testevent"] section with
    # title="This is a test title", city="Redwood City", and the [com]
    # section with name-short=BAR, name-long="Bruce Rafnel".
    # Running -n -e testevent should round-trip these values back to the
    # conf without losing them.
    ./vid-tag -n -e testevent >/dev/null 2>&1

    grep -q 'name-short = BAR' ./vid-tag.conf
    assertTrue "$LINENO BAR preserved" "[ $? -eq 0 ]"

    grep -q 'name-long = Bruce Rafnel' ./vid-tag.conf
    assertTrue "$LINENO Bruce Rafnel preserved" "[ $? -eq 0 ]"

    grep -q 'city = Redwood City' ./vid-tag.conf
    assertTrue "$LINENO Redwood City preserved" "[ $? -eq 0 ]"

    grep -q 'title = This is a test title' ./vid-tag.conf
    assertTrue "$LINENO title preserved" "[ $? -eq 0 ]"

    grep -q 'keyword = PBP,Protest' ./vid-tag.conf
    assertTrue "$LINENO keyword preserved" "[ $? -eq 0 ]"
    return 0
} # testCliReadsExistingConf

# --------------------------------
testCliCmdLineOverridesConf() {
    # The conf has city="Redwood City"; -c overrides it
    ./vid-tag -n -e testevent -c "OVERRIDE City" >/dev/null 2>&1

    grep -q 'city = OVERRIDE City' ./vid-tag.conf
    assertTrue "$LINENO override city" "[ $? -eq 0 ]"

    grep -q 'city = Redwood City' ./vid-tag.conf
    assertFalse "$LINENO old city gone" "[ $? -eq 0 ]"
    return 0
} # testCliCmdLineOverridesConf

# --------------------------------
testCliEventNotInConf() {
    local tResult

    # The unzipped conf has only [vid-tag "testevent"]. Asking for an
    # unknown event when the conf exists → "Event not found".
    tResult=$(./vid-tag -n -e doesnotexist 2>&1)
    assertContains "$LINENO event not found" "$tResult" "Event not found"
    return 0
} # testCliEventNotInConf

# ========================================
# Full-pipeline CLI tests
#
# These tests run ./vid-tag end-to-end on the three video files that
# come out of vid-tag-test-input.zip:
#
#     MVI_0107.MP4   270 MiB   Canon VIXIA HF R40,  CreateDate 2016:11:21 00:20:59
#     MVI_0110.MP4   114 MiB   Canon VIXIA HF R40,  CreateDate 2016:11:21 00:29:11
#     MVI_0746.MP4   4.2 GB    Canon VIXIA HF R800, CreateDate 2026:03:01 19:57:49
#
# Each test does its own run because tearDown wipes ./output/ between
# tests.  The MVI_0746.MP4 run includes ffmpeg-splitting a 23-minute
# 4.2 GB file into three 10-minute parts; expect the full-run tests
# to take a long time on a real machine.
#
# All asserts ignore the trailing " [NNN]" line-number markers via
# fStripLine; date asserts use only the date+time portion of exiftool
# output (no timezone) so they are portable across hosts.
# ========================================

# --------------------------------
fHelperRunFullPipeline() {
    # Wipe any previous output, then run ./vid-tag with all three test
    # input files at -vv (info-level).  Stdout/stderr are stripped of
    # line-number markers and echoed back to the caller.
    rm -rf ./output 2>/dev/null
    ./vid-tag -vv -e testevent \
        MVI_0107.MP4 MVI_0110.MP4 MVI_0746.MP4 2>&1 | fStripLine
} # fHelperRunFullPipeline

# --------------------------------
testCliFullRunStdout() {
    # Run vid-tag against all three test-input files and verify the
    # expected log messages appear on stdout (which fLog routes to
    # stderr - merged here with 2>&1).
    local tResult

    tResult=$(fHelperRunFullPipeline)

    # ----- Conf save / output dir creation -----
    assertContains "$LINENO save conf"   "$tResult" \
        "Saving local config: ./vid-tag.conf (tag=testevent)"
    assertContains "$LINENO output dir"  "$tResult" \
        "Created output dir: output"

    # ----- Copy phase: one Copy line per input file -----
    assertContains "$LINENO copy 0107"   "$tResult" \
        "Copy: MVI_0107.MP4 -> output/MVI_0107.MP4"
    assertContains "$LINENO copy 0110"   "$tResult" \
        "Copy: MVI_0110.MP4 -> output/MVI_0110.MP4"
    assertContains "$LINENO copy 0746"   "$tResult" \
        "Copy: MVI_0746.MP4 -> output/MVI_0746.MP4"

    # ----- Processing announcement per file -----
    assertContains "$LINENO proc 0107"   "$tResult" \
        "Processing: MVI_0107.MP4"
    assertContains "$LINENO proc 0110"   "$tResult" \
        "Processing: MVI_0110.MP4"
    assertContains "$LINENO proc 0746"   "$tResult" \
        "Processing: MVI_0746.MP4"

    # ----- Rename: input -> dated/event/photog/file pattern -----
    assertContains "$LINENO rename 0107" "$tResult" \
        "Rename: MVI_0107.MP4 -> 2016-11-21_testevent_BAR_MVI_0107.MP4"
    assertContains "$LINENO rename 0110" "$tResult" \
        "Rename: MVI_0110.MP4 -> 2016-11-21_testevent_BAR_MVI_0110.MP4"
    assertContains "$LINENO rename 0746" "$tResult" \
        "Rename: MVI_0746.MP4 -> 2026-03-01_testevent_BAR_MVI_0746.MP4"

    # ----- exiftool command-line tag values come from the conf -----
    # Title pattern expanded per file (date varies; 0107 and 0110 share
    # the same date, 0746 has its own).
    assertContains "$LINENO 0107 -Title" "$tResult" \
        "-Title=2016-11-21 Mon, Redwood City, This is a test title, by Bruce Rafnel."
    assertContains "$LINENO 0746 -Title" "$tResult" \
        "-Title=2026-03-01 Sun, Redwood City, This is a test title, by Bruce Rafnel."

    assertContains "$LINENO -FileName 0107" "$tResult" \
        "-FileName=2016-11-21_testevent_BAR_MVI_0107.MP4"
    assertContains "$LINENO -FileName 0110" "$tResult" \
        "-FileName=2016-11-21_testevent_BAR_MVI_0110.MP4"
    assertContains "$LINENO -FileName 0746" "$tResult" \
        "-FileName=2026-03-01_testevent_BAR_MVI_0746.MP4"

    assertContains "$LINENO -Copyright" "$tResult" \
        "-Copyright=Copyright Bruce Rafnel 2026"
    assertContains "$LINENO -Artist"    "$tResult" \
        "-Artist=Copyright Bruce Rafnel 2026"
    assertContains "$LINENO -Author"    "$tResult" \
        "-Author=Bruce Rafnel"
    assertContains "$LINENO -Keywords"  "$tResult" \
        "-Keywords=PBP,Protest"
    assertContains "$LINENO -Caption"   "$tResult" \
        "-Caption=This photo or video may be downloaded and used freely"
    assertContains "$LINENO -Description" "$tResult" \
        "-Description=This photo or video may be downloaded and used freely"
    assertContains "$LINENO -ImageDescription" "$tResult" \
        "-ImageDescription=This photo or video may be downloaded and used freely"
    assertContains "$LINENO CC license" "$tResult" \
        "https://creativecommons.org/licenses/by-nc/4.0/"

    # ----- exiftool reports "1 image files updated" for each processed file -----
    assertContains "$LINENO 1 file updated" "$tResult" \
        "1 image files updated"

    # ----- touch -t with the exif CreateDate (HHMM.SS, no timezone) -----
    assertContains "$LINENO touch 0107" "$tResult" \
        "touch -t 201611210020.59 2016-11-21_testevent_BAR_MVI_0107.MP4"
    assertContains "$LINENO touch 0110" "$tResult" \
        "touch -t 201611210029.11 2016-11-21_testevent_BAR_MVI_0110.MP4"
    assertContains "$LINENO touch 0746" "$tResult" \
        "touch -t 202603011957.49 2026-03-01_testevent_BAR_MVI_0746.MP4"

    # ----- Splitting: only MVI_0746.MP4 is > 10 minutes (23:45) -----
    assertContains "$LINENO split"        "$tResult" \
        "Split 2026-03-01_testevent_BAR_MVI_0746.MP4 into 10min parts"
    assertContains "$LINENO copy exif"    "$tResult" \
        "Copy the exif data from original"

    # The TagsFromFile invocations - one per split part
    assertContains "$LINENO tags 00"      "$tResult" \
        "exiftool -TagsFromFile 2026-03-01_testevent_BAR_MVI_0746.MP4 -all:all"
    assertContains "$LINENO tags 00 part" "$tResult" \
        "2026-03-01_testevent_BAR_MVI_0746-00.mp4"
    assertContains "$LINENO tags 01 part" "$tResult" \
        "2026-03-01_testevent_BAR_MVI_0746-01.mp4"
    assertContains "$LINENO tags 02 part" "$tResult" \
        "2026-03-01_testevent_BAR_MVI_0746-02.mp4"

    # The split exclude-list (kept-from-original) tags
    assertContains "$LINENO tags keep" "$tResult" \
        "--FileName --Title --Caption --CaptionAbstract --Copyright --Artist --Author --Keywords --*date* --MakerNotes"

    assertContains "$LINENO fix ts"       "$tResult" \
        "Fix the timestamps"
    assertContains "$LINENO touch parts"  "$tResult" \
        "touch -t 202603011957.49 2026-03-01_testevent_BAR_MVI_0746-*.mp4"

    # ----- Final notice -----
    assertContains "$LINENO done"         "$tResult" "Done."

    # ----- The two short files must NOT be split (under 10 min) -----
    if echo "$tResult" | grep -q "Split.*MVI_0107"; then
        fail "$LINENO MVI_0107 should not be split (only 1:36 long)"
    fi
    if echo "$tResult" | grep -q "Split.*MVI_0110"; then
        fail "$LINENO MVI_0110 should not be split (only 0:41 long)"
    fi
    return 0
} # testCliFullRunStdout

# --------------------------------
testCliFullRunOutputFiles() {
    # Run vid-tag and verify all expected files end up in ./output/
    # with the expected (dated/event/photog/file pattern) names.

    fHelperRunFullPipeline >/dev/null

    # ----- The renamed primary files -----
    assertTrue "$LINENO 0107 exists" \
        "[ -f ./output/2016-11-21_testevent_BAR_MVI_0107.MP4 ]"
    assertTrue "$LINENO 0110 exists" \
        "[ -f ./output/2016-11-21_testevent_BAR_MVI_0110.MP4 ]"
    assertTrue "$LINENO 0746 exists" \
        "[ -f ./output/2026-03-01_testevent_BAR_MVI_0746.MP4 ]"

    # ----- The 4.2GB / 23:45 file is split into three 10-min parts -----
    assertTrue "$LINENO 0746-00 exists" \
        "[ -f ./output/2026-03-01_testevent_BAR_MVI_0746-00.mp4 ]"
    assertTrue "$LINENO 0746-01 exists" \
        "[ -f ./output/2026-03-01_testevent_BAR_MVI_0746-01.mp4 ]"
    assertTrue "$LINENO 0746-02 exists" \
        "[ -f ./output/2026-03-01_testevent_BAR_MVI_0746-02.mp4 ]"

    # ----- The original (un-renamed) names must NOT remain in ./output/ -----
    assertFalse "$LINENO no orig 0107" \
        "[ -f ./output/MVI_0107.MP4 ]"
    assertFalse "$LINENO no orig 0110" \
        "[ -f ./output/MVI_0110.MP4 ]"
    assertFalse "$LINENO no orig 0746" \
        "[ -f ./output/MVI_0746.MP4 ]"

    # ----- exiftool's "_original" backup files are removed by vid-tag -----
    if ls ./output/*_original 2>/dev/null | grep -q .; then
        fail "$LINENO _original backups not cleaned up"
    fi

    # ----- The two short files (MVI_0107 / MVI_0110) must NOT be split -----
    if ls ./output/2016-11-21_testevent_BAR_MVI_0107-*.mp4 2>/dev/null | grep -q .; then
        fail "$LINENO MVI_0107 should not be split"
    fi
    if ls ./output/2016-11-21_testevent_BAR_MVI_0110-*.mp4 2>/dev/null | grep -q .; then
        fail "$LINENO MVI_0110 should not be split"
    fi
    return 0
} # testCliFullRunOutputFiles

# --------------------------------
testCliFullRunExif_MVI0107() {
    # Verify the exif tags written to the renamed MVI_0107 output file.
    local tFile
    local tExif

    fHelperRunFullPipeline >/dev/null

    tFile="./output/2016-11-21_testevent_BAR_MVI_0107.MP4"
    assertTrue "$LINENO file exists" "[ -f $tFile ]"

    tExif=$(exiftool "$tFile" 2>&1)

    # ----- Tags written by vid-tag (from the testevent / com config) -----
    assertContains "$LINENO Title"      "$tExif" \
        "Title                           : 2016-11-21 Mon, Redwood City, This is a test title, by Bruce Rafnel."
    assertContains "$LINENO Caption"    "$tExif" \
        "Caption                         : This photo or video may be downloaded and used freely"
    assertContains "$LINENO Description" "$tExif" \
        "Description                     : This photo or video may be downloaded and used freely"
    assertContains "$LINENO ImageDesc"  "$tExif" \
        "Image Description               : This photo or video may be downloaded and used freely"
    assertContains "$LINENO Caption CC" "$tExif" \
        "https://creativecommons.org/licenses/by-nc/4.0/"
    assertContains "$LINENO Keywords"   "$tExif" \
        "Keywords                        : PBP,Protest"
    assertContains "$LINENO Copyright"  "$tExif" \
        "Copyright                       : Copyright Bruce Rafnel 2026"
    assertContains "$LINENO Artist"     "$tExif" \
        "Artist                          : Copyright Bruce Rafnel 2026"
    assertContains "$LINENO Author"     "$tExif" \
        "Author                          : Bruce Rafnel"

    # ----- Original exif dates from the source must be preserved -----
    assertContains "$LINENO DateTimeOriginal" "$tExif" \
        "Date/Time Original              : 2016:11:21 00:20:58"
    assertContains "$LINENO CreateDate" "$tExif" \
        "Create Date                     : 2016:11:21 00:20:59"
    assertContains "$LINENO ModifyDate" "$tExif" \
        "Modify Date                     : 2016:11:21 00:20:59"

    # ----- File-system mtime aligned with the exif CreateDate.
    #       Match only date+time, not timezone (timezone varies by host). -----
    assertContains "$LINENO File mod date" "$tExif" \
        "File Modification Date/Time     : 2016:11:21 00:20:59"

    # ----- Original camera info is preserved (not overwritten) -----
    assertContains "$LINENO Camera Model" "$tExif" \
        "Camera Model Name               : Canon VIXIA HF R40"
    assertContains "$LINENO Make"        "$tExif" \
        "Make                            : Canon"
    return 0
} # testCliFullRunExif_MVI0107

