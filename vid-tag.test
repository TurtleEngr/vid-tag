# --------------------------------
testCliFullRunExif_MVI0746_Splits() {
    # Verify the exif tags on the three 10-minute split parts.  Each
    # part has metadata copied from the parent via -TagsFromFile, but
    # excluding FileName, Title/Caption/Copyright/Artist/Author/Keywords
    # (those come from the per-part tag-set), all "*date*" fields
    # (preserved from the split itself), and MakerNotes.
    #
    # Note that exiftool's -TagsFromFile then fills the kept tags
    # (Title, Caption, etc.) FROM the parent, so the per-part files
    # end up carrying the same vid-tag-written values as the parent.
    local tPart
    local tFile
    local tExif
    local tMeta
    local tValue

    fHelperRunFullPipeline >/dev/null

    for tPart in 00 01 02; do
        tFile="./output/2026-03-01_testevent_BAR_MVI_0746-${tPart}.mp4"
        assertTrue "$LINENO part $tPart exists" "[ -f $tFile ]"
        if [[ ! -f $tFile ]]; then
            continue
        fi

        tExif=$(exiftool "$tFile" 2>&1)

        # Title/Caption/Keywords/Copyright/Artist/Author copied from parent.
        tMeta=$(echo "$tExif" | grep '^Title ')
        assertContains "$LINENO part $tPart Title" "$tMeta" "Title "
        assertContains "$LINENO part $tPart Title" "$tMeta" \
            " : 2026-03-01 Sun, Redwood City, This is a test title, by Bruce Rafnel."
        tMeta=$(echo "$tExif" | grep '^Caption ')
        assertContains "$LINENO part $tPart Caption" "$tMeta" "Caption "
        assertContains "$LINENO part $tPart Caption" "$tMeta" \
                       " : This photo or video may be downloaded and used freely"
        
        tMeta=$(echo "$tExif" | grep '^Keywords ')
        assertContains "$LINENO part $tPart Keywords" "$tMeta" "Keywords"
        assertContains "$LINENO part $tPart Keywords" "$tMeta" \
                       " : PBP,Protest"
        
        tMeta=$(echo "$tExif" | grep '^Copyright ')
        assertContains "$LINENO part $tPart Copyright" "$tMeta" "Copyright "
        assertContains "$LINENO part $tPart Copyright" "$tMeta" \
                       " : Copyright Bruce Rafnel 2026"
        
        tMeta=$(echo "$tExif" | grep '^Artist ')
        assertContains "$LINENO part $tPart Artist" "$tMeta" "Artist "
        assertContains "$LINENO part $tPart Artist" "$tMeta" "Artist " \
                       " : Copyright Bruce Rafnel 2026"

        tMeta=$(echo "$tExif" | grep '^Author ')
        assertContains "$LINENO part $tPart Author" "$tMeta" "Author "
        assertContains "$LINENO part $tPart Author" "$tMeta" \
                       " : Bruce Rafnel"

        # Each part's file modification time is touched to the parent's
        # CreateDate (no timezone in the assert).
        assertContains "$LINENO part $tPart mod date" "$tExif" \
            "File Modification Date/Time     : 2026:03:01 19:57:49"

        # The file should NOT contain the parent's exact Date/Time
        # Original / CreateDate (those date fields are excluded by the
        # --*date* in the TagsFromFile -keep list, so the part keeps
        # whatever ffmpeg put on the segment).
    done
    return 0
} # testCliFullRunExif_MVI0746_Splits

# --------------------------------
testCliFullRunNoExtra() {
    # The conf has no "extra =" key in [vid-tag "testevent"], so the
    # output Title must NOT have a trailing extra phrase appended.
    # (gpEventExtra="" => no "$gpEventExtra." suffix added in fProcessFile.)
    local tFile
    local tTitle

    fHelperRunFullPipeline >/dev/null

    tFile="./output/2016-11-21_testevent_BAR_MVI_0107.MP4"
    assertTrue "$LINENO file exists" "[ -f $tFile ]"

    # exiftool -s3 prints just the value of the requested tag.
    tTitle=$(exiftool -s3 -Title "$tFile" 2>/dev/null)
    assertEquals "$LINENO 0107 title (no extra)" \
        "2016-11-21 Mon, Redwood City, This is a test title, by Bruce Rafnel." \
        "$tTitle"
    return 0
} # testCliFullRunNoExtra

